{% extends 'base.html.twig' %}

{% block title %}F76 Item Tracker{% endblock %}

{% block body %}
    <main class="catalog-page">
        <header class="catalog-header">
            <p class="catalog-kicker">Fallout 76</p>
            <h1>Item Knowledge Tracker</h1>
            <p class="catalog-subtitle">Selectionne un player puis marque ses plans Minerva et legendary mods.</p>
            <p class="catalog-user">Connecte: <strong>{{ username }}</strong> · <a href="{{ path('app_logout') }}">Logout</a></p>
        </header>

        <section
            class="catalog-shell"
            data-controller="item-catalog"
            data-item-catalog-players-url-value="{{ apiPlayersUrl }}"
            data-item-catalog-players-base-url-value="{{ apiPlayersBaseUrl }}"
            data-item-catalog-initial-player-id-value="{{ activePlayerId ?? '' }}"
            data-item-catalog-initial-type-value="BOOK"
        >
            <div class="catalog-toolbar">
                <label class="field">
                    <span>Player</span>
                    <select data-item-catalog-target="playerSelect"></select>
                </label>
                <fieldset class="type-switch">
                    <legend>Type</legend>
                    <label>
                        <input type="radio" name="item-type" value="BOOK" checked data-item-catalog-target="typeInput">
                        BOOK
                    </label>
                    <label>
                        <input type="radio" name="item-type" value="MISC" data-item-catalog-target="typeInput">
                        MISC
                    </label>
                </fieldset>
            </div>

            <p class="catalog-state" data-item-catalog-target="state">Chargement...</p>
            <ul class="item-grid" data-item-catalog-target="list"></ul>
        </section>
    </main>
{% endblock %}
