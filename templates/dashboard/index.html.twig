{% extends 'base.html.twig' %}

{% block title %}F76 - Suivi des objets{% endblock %}

{% block body %}
    <main class="catalog-page">
        <header class="catalog-header">
            <p class="catalog-kicker">Fallout 76</p>
            <h1>Suivi des objets appris</h1>
            <p class="catalog-subtitle">Selectionne un personnage puis marque ses plans Minerva et ses mods legendaires appris.</p>
            <p class="catalog-user">
                Utilisateur connecte: <strong>{{ username }}</strong>
                · <a href="{{ path('app_admin_item_translations', { locale: app.request.locale }) }}">Backoffice des traductions</a>
                · <a href="{{ path('app_logout', { locale: app.request.locale }) }}">Se deconnecter</a>
            </p>
            <p class="catalog-user">
                Langue:
                <a href="{{ path('app_dashboard', { locale: 'fr' }) }}">FR</a>
                · <a href="{{ path('app_dashboard', { locale: 'en' }) }}">EN</a>
                · <a href="{{ path('app_dashboard', { locale: 'de' }) }}">DE</a>
            </p>
        </header>

        <section
            class="catalog-shell"
            data-controller="item-catalog"
            data-item-catalog-players-url-value="{{ apiPlayersUrl }}"
            data-item-catalog-players-base-url-value="{{ apiPlayersBaseUrl }}"
            data-item-catalog-initial-player-id-value="{{ activePlayerId ?? '' }}"
        >
            <section class="catalog-panel">
                <h2>Filtres</h2>
                <div class="catalog-toolbar">
                    <label class="field">
                        <span>Personnage</span>
                        <select data-item-catalog-target="playerSelect"></select>
                    </label>
                    <label class="field">
                        <span>Nouveau personnage</span>
                        <div class="field-inline">
                            <input type="text" placeholder="Nom du personnage" data-item-catalog-target="createNameInput">
                            <button type="button" data-item-catalog-target="createButton">Creer</button>
                        </div>
                    </label>
                    <label class="field">
                        <span>Recherche</span>
                        <input type="search" placeholder="Nom, description, cle..." data-item-catalog-target="searchInput">
                    </label>
                    <fieldset class="source-filters">
                        <legend>Filtres sources</legend>
                        <label><input type="checkbox" data-item-catalog-target="sourceFilter" value="dropRaid"><img src="/assets/icons/GleamingDepthsMarker.svg" alt="">Raid</label>
                        <label><input type="checkbox" data-item-catalog-target="sourceFilter" value="dropBurningSprings"><img src="/assets/icons/bounty_hunter_ghoul_icon_128.png" alt="">Burning Springs</label>
                        <label><input type="checkbox" data-item-catalog-target="sourceFilter" value="dropDailyOps"><img src="/assets/icons/FO76_dailyops_uplink.png" alt="">Operations quotidiennes</label>
                        <label><input type="checkbox" data-item-catalog-target="sourceFilter" value="vendorRegs"><img src="/assets/icons/Vault79Marker.svg" alt="">Regs</label>
                        <label><input type="checkbox" data-item-catalog-target="sourceFilter" value="vendorSamuel"><img src="/assets/icons/HammerWingMarker.svg" alt="">Samuel</label>
                        <label><input type="checkbox" data-item-catalog-target="sourceFilter" value="vendorMortimer"><img src="/assets/icons/SkullRingMarker.svg" alt="">Mortimer</label>
                    </fieldset>
                </div>
                <p class="catalog-state" data-item-catalog-target="state">Chargement...</p>
            </section>
            <section class="catalog-panel catalog-block">
                <h2>Mods legendaires (par rang)</h2>
                <div data-item-catalog-target="miscList"></div>
            </section>
            <section class="catalog-panel catalog-block">
                <h2>Plans Minerva (par liste)</h2>
                <div data-item-catalog-target="bookList"></div>
            </section>
        </section>
    </main>
{% endblock %}
