{% extends 'base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block body %}
    <main style="max-width: 720px; margin: 2rem auto; font-family: system-ui, sans-serif;">
        <h1>Webapp Symfony</h1>
        <p>Les donnees ci-dessous viennent de l'API JSON interne.</p>

        <section
            data-controller="api-feed"
            data-api-feed-url-value="{{ apiEndpoint }}"
        >
            <p data-api-feed-target="state">Chargement...</p>
            <ul data-api-feed-target="list"></ul>
        </section>
    </main>
{% endblock %}
