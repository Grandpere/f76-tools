{% extends 'base.html.twig' %}

{% block title %}{{ 'catalog_books.page_title'|trans }}{% endblock %}

{% block body %}
    {% set uiTranslations = {
        loadingPlayers: 'dashboard.state.loading_players'|trans,
        cannotLoadPlayers: 'dashboard.state.cannot_load_players'|trans,
        noPlayers: 'dashboard.state.no_players'|trans,
        noSelectedPlayer: 'dashboard.state.no_selected_player'|trans,
        loadingItems: 'dashboard.state.loading_items'|trans,
        updateFailed: 'dashboard.state.update_failed'|trans,
        ariaItemLearned: 'dashboard.aria.item_learned'|trans
    } %}
    {% if catalogUpdatedAt %}
        {% set updatedLabel = 'catalog_books.last_updated'|trans({'%date%': catalogUpdatedAt|date('d/m/Y H:i')}) %}
    {% else %}
        {% set updatedLabel = 'catalog_books.last_updated_unknown'|trans %}
    {% endif %}

    <main class="catalog-page">
        {% include '_app_page_header.html.twig' with {
            localeSelectId: 'catalog-books-header-locale-select',
            title: 'catalog_books.title',
            subtitle: 'catalog_books.description',
            activeNav: 'plans-recipes',
            extraState: updatedLabel
        } %}

        <section
            class="catalog-shell"
            data-controller="catalog-filters book-catalog-knowledge"
            data-book-catalog-knowledge-players-url-value="{{ apiPlayersUrl }}"
            data-book-catalog-knowledge-players-base-url-value="{{ apiPlayersBaseUrl }}"
            data-book-catalog-knowledge-initial-player-id-value="{{ activePlayerId ?? '' }}"
            data-book-catalog-knowledge-storage-key-value="{{ storageKey }}"
            data-book-catalog-knowledge-locale-value="{{ app.request.locale }}"
            data-book-catalog-knowledge-ui-translations-value="{{ uiTranslations|json_encode|e('html_attr') }}"
        >
            <section class="catalog-panel filters-panel">
                <h2>{{ 'catalog_books.filters_title'|trans }}</h2>
                <form method="get" action="{{ path('app_book_catalog', { _locale: app.request.locale }) }}" class="catalog-toolbar" data-catalog-filters-target="form">
                    <input type="hidden" name="page" value="{{ page }}" data-catalog-filters-target="pageInput">
                    <input type="hidden" name="player" value="{{ selectedPlayerId }}" data-book-catalog-knowledge-target="playerInput">
                    <label class="field">
                        <span>{{ 'dashboard.filters.player'|trans }}</span>
                        <select data-book-catalog-knowledge-target="playerSelect"></select>
                    </label>
                    <label class="field">
                        <span>{{ 'catalog_books.search'|trans }}</span>
                        <input type="search" name="q" value="{{ query }}" placeholder="{{ 'catalog_books.search_placeholder'|trans }}" data-catalog-filters-target="searchInput">
                    </label>
                    <label class="field">
                        <span>{{ 'catalog_books.per_page'|trans }}</span>
                        <select name="perPage">
                            {% for option in [24, 48, 72, 96] %}
                                <option value="{{ option }}" {% if perPage == option %}selected{% endif %}>{{ option }}</option>
                            {% endfor %}
                        </select>
                    </label>
                    <label class="field">
                        <span>{{ 'catalog_books.sort'|trans }}</span>
                        <select name="sort">
                            {% for option in sortOptions %}
                                <option value="{{ option }}" {% if selectedSort == option %}selected{% endif %}>{{ ('catalog_books.sort_' ~ option)|trans }}</option>
                            {% endfor %}
                        </select>
                    </label>
                    <fieldset class="source-filters catalog-books-list-filters">
                        <legend>{{ 'catalog_books.progress_and_type_filters'|trans }}</legend>
                        <div class="source-filter-groups">
                            <div class="source-filter-group">
                                <p class="source-filter-group-title">{{ 'catalog_books.knowledge_filters'|trans }}</p>
                                <div class="source-filter-options">
                                    {% for option in ['all', 'unlearned', 'learned'] %}
                                        <label>
                                            <input type="radio" name="knowledge" value="{{ option }}" {% if selectedKnowledge == option %}checked{% endif %}>
                                            <span>{{ ('catalog_books.knowledge_' ~ option)|trans }}</span>
                                        </label>
                                    {% endfor %}
                                </div>
                            </div>

                            <div class="source-filter-group">
                                <p class="source-filter-group-title">{{ 'catalog_books.kind_filters'|trans }}</p>
                                <div class="source-filter-options">
                                    {% for option in kindOptions %}
                                        <label>
                                            <input type="checkbox" name="kinds[]" value="{{ option }}" {% if option in selectedKinds %}checked{% endif %}>
                                            <span>{{ ('catalog_books.kind_' ~ option)|trans }}</span>
                                        </label>
                                    {% endfor %}
                                </div>
                            </div>
                        </div>
                    </fieldset>

                    <fieldset class="source-filters catalog-books-list-filters">
                        <legend>{{ 'catalog_books.taxonomy_filters'|trans }}</legend>
                        <div class="source-filter-groups catalog-taxonomy-groups">
                            <div class="source-filter-group">
                                <p class="source-filter-group-title">{{ 'catalog_books.category_filters'|trans }}</p>
                                <div class="source-filter-options catalog-taxonomy-category-grid">
                                    {% for option in categoryOptions %}
                                        <label>
                                            <input type="checkbox" name="categories[]" value="{{ option }}" {% if option in selectedCategories %}checked{% endif %}>
                                            {% if categoryIconMap[option] is defined %}
                                                <img src="{{ asset(categoryIconMap[option]) }}" alt="" aria-hidden="true" class="catalog-category-icon">
                                            {% endif %}
                                            <span>{{ ('catalog_books.category_' ~ option)|trans }}</span>
                                        </label>
                                    {% endfor %}
                                </div>
                            </div>
                            {% if subcategoryOptions is not empty %}
                                <div class="source-filter-group catalog-taxonomy-subcategory-block">
                                    <p class="source-filter-group-title">{{ 'catalog_books.subcategory_filters'|trans }}</p>
                                    <div class="catalog-note info-note catalog-taxonomy-info-note">
                                        <span class="info-note-content">
                                            {{ 'catalog_books.category_armor_plan_hint'|trans }}
                                            {{ 'catalog_books.category_armor_mod_plan_hint'|trans }}
                                        </span>
                                    </div>
                                    {% set taxonomyDisplayGroups = [
                                        ['weapon_plan', 'weapon_mod_plan', 'apparel_plan'],
                                        ['armor_plan', 'armor_mod_plan'],
                                        ['power_armor_plan', 'power_armor_mod_plan'],
                                        ['workshop_plan'],
                                        ['recipe']
                                    ] %}
                                    <div class="source-filter-groups catalog-taxonomy-subcategory-groups">
                                        {% for categoryGroup in taxonomyDisplayGroups %}
                                            <div class="catalog-taxonomy-subcategory-column">
                                                {% for category in categoryGroup %}
                                                    {% set optionsForCategory = [] %}
                                                    {% for option in subcategoryOptions %}
                                                        {% if option.category == category %}
                                                            {% set optionsForCategory = optionsForCategory|merge([option]) %}
                                                        {% endif %}
                                                    {% endfor %}
                                                    {% for option in detailOptions %}
                                                        {% if option.category == category %}
                                                            {% set optionsForCategory = optionsForCategory|merge([{
                                                                id: option.id,
                                                                label: option.label,
                                                                isDetail: true
                                                            }]) %}
                                                        {% endif %}
                                                    {% endfor %}
                                                    {% if category in categoryOptions %}
                                                        <div class="source-filter-group">
                                                            {% set hasDetailOptions = false %}
                                                            {% for option in optionsForCategory %}
                                                                {% if option.isDetail is defined and option.isDetail %}
                                                                    {% set hasDetailOptions = true %}
                                                                {% endif %}
                                                            {% endfor %}
                                                            <p class="source-filter-group-title">
                                                                {{ ('catalog_books.category_' ~ category)|trans }}
                                                            </p>
                                                            {% if optionsForCategory is not empty %}
                                                                <div class="source-filter-options catalog-taxonomy-subcategory-row">
                                                                    {% for option in optionsForCategory %}
                                                                        <label>
                                                                            <input
                                                                                type="checkbox"
                                                                                name="{% if option.isDetail is defined and option.isDetail %}details[]{% else %}subcategories[]{% endif %}"
                                                                                value="{{ option.id }}"
                                                                                {% if option.isDetail is defined and option.isDetail %}
                                                                                    {% if option.id in selectedDetails %}checked{% endif %}
                                                                                {% else %}
                                                                                    {% if option.id in selectedSubcategories %}checked{% endif %}
                                                                                {% endif %}
                                                                            >
                                                                            <span>{{ option.label }}</span>
                                                                        </label>
                                                                    {% endfor %}
                                                                </div>
                                                            {% else %}
                                                                <p class="catalog-taxonomy-empty">—</p>
                                                            {% endif %}
                                                        </div>
                                                    {% endif %}
                                                {% endfor %}
                                            </div>
                                        {% endfor %}
                                    </div>
                                </div>
                            {% endif %}
                        </div>
                    </fieldset>

                    <fieldset class="source-filters catalog-books-list-filters">
                        <legend>{{ 'catalog_books.list_filter'|trans }}</legend>
                        <div class="source-filter-groups">
                            {% for optionGroup in listOptions|batch(4, null) %}
                                <div class="source-filter-group">
                                    <div class="source-filter-options">
                                        {% for option in optionGroup %}
                                            {% if option is not null %}
                                                <label class="{% if option is divisible by(4) %}catalog-list-option-special{% endif %}">
                                                    <input type="checkbox" name="lists[]" value="{{ option }}" {% if (option ~ '') in selectedLists %}checked{% endif %}>
                                                    {{ 'catalog_books.list_option'|trans({'%list%': option}) }}
                                                </label>
                                            {% endif %}
                                        {% endfor %}
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    </fieldset>

                    <fieldset class="source-filters catalog-books-list-filters">
                        <legend>{{ 'catalog_books.vendor_filters'|trans }}</legend>
                        <div class="source-filter-groups">
                            {% if 'vendors' in vendorFilterOptions %}
                                <div class="source-filter-group">
                                    <p class="source-filter-group-title">{{ 'catalog_books.vendor_group_all'|trans }}</p>
                                    <div class="source-filter-options">
                                        <label>
                                            <input type="checkbox" name="vendorFilters[]" value="vendors" {% if 'vendors' in selectedVendorFilters %}checked{% endif %}>
                                            {% if signalIconMap.vendors is defined %}
                                                <img src="{{ asset(signalIconMap.vendors) }}" alt="" aria-hidden="true">
                                            {% endif %}
                                            <span>{{ 'catalog_books.vendors'|trans }}</span>
                                        </label>
                                    </div>
                                </div>
                            {% endif %}

                            {% set bullionVendorOptions = ['vendor_minerva', 'vendor_regs', 'vendor_samuel', 'vendor_mortimer'] %}
                            {% set hasBullionVendorOptions = false %}
                            {% for option in bullionVendorOptions %}
                                {% if option in vendorFilterOptions %}
                                    {% set hasBullionVendorOptions = true %}
                                {% endif %}
                            {% endfor %}

                            {% if hasBullionVendorOptions %}
                                <div class="source-filter-group">
                                    <p class="source-filter-group-title">{{ 'catalog_books.vendor_group_bullion'|trans }}</p>
                                    <div class="source-filter-options">
                                        {% for option in bullionVendorOptions %}
                                            {% if option in vendorFilterOptions %}
                                                <label>
                                                    <input type="checkbox" name="vendorFilters[]" value="{{ option }}" {% if option in selectedVendorFilters %}checked{% endif %}>
                                                    {% if option == 'vendor_minerva' %}
                                                        <span class="catalog-vendor-text-icon" aria-hidden="true">M</span>
                                                    {% endif %}
                                                    {% if option == 'vendor_regs' %}
                                                        <img src="{{ asset('/assets/icons/Vault79Marker.svg') }}" alt="" aria-hidden="true">
                                                    {% endif %}
                                                    {% if option == 'vendor_samuel' %}
                                                        <img src="{{ asset('/assets/icons/HammerWingMarker.svg') }}" alt="" aria-hidden="true">
                                                    {% endif %}
                                                    {% if option == 'vendor_mortimer' %}
                                                        <img src="{{ asset('/assets/icons/SkullRingMarker.svg') }}" alt="" aria-hidden="true">
                                                    {% endif %}
                                                    <span>{{ ('catalog_books.' ~ option)|trans }}</span>
                                                </label>
                                            {% endif %}
                                        {% endfor %}
                                    </div>
                                </div>
                            {% endif %}

                            {% if 'vendor_giuseppe' in vendorFilterOptions %}
                                <div class="source-filter-group">
                                    <p class="source-filter-group-title">{{ 'catalog_books.vendor_group_stamps'|trans }}</p>
                                    <div class="source-filter-options">
                                        <label>
                                            <input type="checkbox" name="vendorFilters[]" value="vendor_giuseppe" {% if 'vendor_giuseppe' in selectedVendorFilters %}checked{% endif %}>
                                            <img src="{{ asset('/assets/icons/WhitespringResortMarker.svg') }}" alt="" aria-hidden="true">
                                            <span>{{ 'catalog_books.vendor_giuseppe'|trans }}</span>
                                        </label>
                                    </div>
                                </div>
                            {% endif %}
                        </div>
                    </fieldset>

                    <fieldset class="source-filters catalog-books-list-filters">
                        <legend>{{ 'catalog_books.signal_filters'|trans }}</legend>
                        <div class="source-filter-groups">
                            {% set repeatableSignalOptions = ['daily_ops', 'expeditions', 'raid', 'events'] %}
                            {% set worldSignalOptions = ['world_spawns', 'containers', 'enemies', 'random_encounters', 'treasure_maps'] %}
                            {% set progressionSignalOptions = ['quests', 'seasonal_content', 'unused_content'] %}

                            {% set signalGroups = [
                                { title: 'catalog_books.signal_group_repeatable', options: repeatableSignalOptions },
                                { title: 'catalog_books.signal_group_world', options: worldSignalOptions },
                                { title: 'catalog_books.signal_group_progression', options: progressionSignalOptions },
                            ] %}

                            {% for group in signalGroups %}
                                {% set hasGroupOptions = false %}
                                {% for option in group.options %}
                                    {% if option in signalOptions %}
                                        {% set hasGroupOptions = true %}
                                    {% endif %}
                                {% endfor %}

                                {% if hasGroupOptions %}
                                    <div class="source-filter-group">
                                        <p class="source-filter-group-title">{{ group.title|trans }}</p>
                                        <div class="source-filter-options">
                                            {% for option in group.options %}
                                                {% if option in signalOptions %}
                                                    <label>
                                                        <input type="checkbox" name="signals[]" value="{{ option }}" {% if option in selectedSignals %}checked{% endif %}>
                                                        {% if signalIconMap[option] is defined %}
                                                            <img src="{{ asset(signalIconMap[option]) }}" alt="" aria-hidden="true">
                                                        {% endif %}
                                                        <span>{{ ('catalog_books.signal_' ~ option)|trans }}</span>
                                                    </label>
                                                {% endif %}
                                            {% endfor %}
                                        </div>
                                    </div>
                                {% endif %}
                            {% endfor %}
                        </div>
                    </fieldset>
                </form>

                {% set legendCategoryOptions = categoryOptions %}
                {% set legendVendorOptions = ['vendor_minerva', 'vendor_regs', 'vendor_samuel', 'vendor_mortimer', 'vendor_giuseppe'] %}
                {% set legendSignalOptions = ['daily_ops', 'expeditions', 'raid', 'events', 'world_spawns', 'containers', 'enemies', 'random_encounters', 'treasure_maps', 'quests', 'seasonal_content', 'unused_content'] %}
                {% set legendCurrencyOptions = ['caps', 'gold_bullion', 'stamps', 'tickets'] %}

                <section class="catalog-icon-legend">
                    <h3>{{ 'catalog_books.legend_title'|trans }}</h3>
                    <p class="catalog-note">{{ 'catalog_books.legend_help'|trans }}</p>

                    <div class="source-filter-groups">
                        <div class="source-filter-group">
                            <p class="source-filter-group-title">{{ 'catalog_books.legend_group_categories'|trans }}</p>
                            <div class="catalog-legend-list">
                                {% for option in legendCategoryOptions %}
                                    <div class="catalog-legend-item">
                                        {% if categoryIconMap[option] is defined %}
                                            <img src="{{ asset(categoryIconMap[option]) }}" alt="" aria-hidden="true" class="catalog-category-icon">
                                        {% endif %}
                                        <span>{{ ('catalog_books.category_' ~ option)|trans }}</span>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>

                        <div class="source-filter-group">
                            <p class="source-filter-group-title">{{ 'catalog_books.legend_group_vendors'|trans }}</p>
                            <div class="catalog-legend-list">
                                {% for option in legendVendorOptions %}
                                    <div class="catalog-legend-item">
                                        {% if option == 'vendor_minerva' %}
                                            <span class="catalog-vendor-text-icon" aria-hidden="true">M</span>
                                        {% elseif vendorIconMap[option] is defined %}
                                            <img src="{{ asset(vendorIconMap[option]) }}" alt="" aria-hidden="true">
                                        {% endif %}
                                        <span>{{ ('catalog_books.' ~ option)|trans }}</span>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>

                        <div class="source-filter-group">
                            <p class="source-filter-group-title">{{ 'catalog_books.legend_group_sources'|trans }}</p>
                            <div class="catalog-legend-list">
                                {% for option in legendSignalOptions %}
                                    {% if signalIconMap[option] is defined %}
                                        <div class="catalog-legend-item">
                                            <img
                                                src="{{ asset(signalIconMap[option]) }}"
                                                alt=""
                                                aria-hidden="true"
                                                class="{% if option == 'random_encounters' %}catalog-icon-random-encounter{% endif %}"
                                            >
                                            <span>{{ ('catalog_books.signal_' ~ option)|trans }}</span>
                                        </div>
                                    {% endif %}
                                {% endfor %}
                            </div>
                        </div>

                        <div class="source-filter-group">
                            <p class="source-filter-group-title">{{ 'catalog_books.legend_group_currencies'|trans }}</p>
                            <div class="catalog-legend-list">
                                {% for option in legendCurrencyOptions %}
                                    {% if currencyIconMap[option] is defined %}
                                        <div class="catalog-legend-item">
                                            <img src="{{ asset(currencyIconMap[option]) }}" alt="" aria-hidden="true">
                                            <span>{{ ('catalog_books.currency_' ~ option)|trans }}</span>
                                        </div>
                                    {% endif %}
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                </section>

                <p class="catalog-state" data-book-catalog-knowledge-target="state" hidden></p>
                {% if selectedPlayerId %}
                    <p class="catalog-state catalog-progress-summary">
                        {{ 'catalog_books.progress_summary'|trans({
                            '%learned%': progressSummary.learned,
                            '%total%': progressSummary.total,
                            '%unlearned%': progressSummary.unlearned,
                            '%percent%': progressSummary.percent
                        }) }}
                    </p>
                {% endif %}

                <p class="catalog-state" data-catalog-filters-target="summary">
                    {{ 'catalog_books.visible_items'|trans({'%count%': items|length, '%total%': totalItems}) }}
                </p>
            </section>

            <section class="catalog-panel catalog-block" data-catalog-filters-target="results" data-book-catalog-knowledge-target="results">
                <h2>{{ 'catalog_books.list_title'|trans }}</h2>
                <p class="catalog-note info-note">
                    <span class="info-note-content">{{ 'dashboard.help.shared_book_learning'|trans }}</span>
                </p>
                <p class="catalog-note">{{ 'catalog_books.list_help'|trans }}</p>

                <div class="item-grid catalog-books-grid">
                    {% for item in items %}
                        <article class="item-card catalog-book-card {{ item.learned ? 'is-learned' : 'is-unlearned' }}" data-book-id="{{ item.id }}">
                            <input
                                class="item-learned-checkbox"
                                type="checkbox"
                                aria-label="{{ 'dashboard.aria.item_learned'|trans }}"
                                data-book-checkbox="1"
                                data-book-id="{{ item.id }}"
                                {% if item.learned %}checked{% endif %}
                                disabled
                            >
                            <div class="item-card-head catalog-book-head">
                                <div class="catalog-book-title-stack">
                                    <strong>{{ item.name }}</strong>
                                </div>
                                <div class="catalog-book-head-badges">
                                    {% if item.isNew %}
                                        <span class="item-badge-new">{{ 'catalog_books.new'|trans }}</span>
                                    {% endif %}
                                </div>
                            </div>

                            <div class="catalog-book-section catalog-book-section-meta">
                                <p class="catalog-book-category-line">
                                    {% if categoryIconMap[item.bookCategory] is defined %}
                                        <img src="{{ asset(categoryIconMap[item.bookCategory]) }}" alt="" aria-hidden="true" class="catalog-category-icon">
                                    {% endif %}
                                    <span>{{ ('catalog_books.category_' ~ item.bookCategory)|trans }}</span>
                                    {% if item.bookSubcategoryLabel %}
                                        <span class="catalog-book-category-separator">•</span>
                                        <span>{{ item.bookSubcategoryLabel }}</span>
                                    {% endif %}
                                    {% if item.bookDetailLabel %}
                                        <span class="catalog-book-category-separator">•</span>
                                        <span>{{ item.bookDetailLabel }}</span>
                                    {% endif %}
                                </p>
                            </div>

                            {% if item.description or item.note or item.unlocks %}
                                <div class="catalog-book-section catalog-book-section-details">
                                    {% if item.description %}
                                        <p>{{ item.description }}</p>
                                    {% endif %}

                                    {% if item.note %}
                                        <p class="item-note-line">{{ item.note }}</p>
                                    {% endif %}

                                    {% if item.unlocks %}
                                        <p class="item-unlocks-line">
                                            <span class="item-unlocks-label">{{ 'catalog_books.unlocks'|trans }}</span>
                                            <span>{{ item.unlocks }}</span>
                                        </p>
                                    {% endif %}
                                </div>
                            {% endif %}

                            {% if item.price or item.priceMinerva %}
                                <div class="catalog-book-section catalog-book-section-prices">
                                    <div class="item-prices">
                                        {% if item.price %}
                                            {% if item.priceMinerva %}
                                                <span>
                                                    {% if currencyIconMap.gold_bullion is defined %}
                                                        <img src="{{ asset(currencyIconMap.gold_bullion) }}" alt="" aria-hidden="true">
                                                    {% endif %}
                                                    {{ item.price }}
                                                </span>
                                            {% else %}
                                                <span>
                                                    {% if currencyIconMap[item.priceCurrencyCode] is defined %}
                                                        <img src="{{ asset(currencyIconMap[item.priceCurrencyCode]) }}" alt="" aria-hidden="true">
                                                    {% endif %}
                                                    {{ 'catalog_books.price'|trans({'%value%': item.price, '%currency%': item.priceCurrencyLabel}) }}
                                                </span>
                                            {% endif %}
                                        {% endif %}
                                        {% if item.priceMinerva %}
                                            <span class="price-new">
                                                <span class="catalog-vendor-text-icon" title="{{ 'catalog_books.vendor_minerva'|trans }}">M</span>
                                                {{ item.priceMinerva }}
                                            </span>
                                        {% endif %}
                                    </div>
                                </div>
                            {% endif %}

                            {% set hasVendorFooterIcons = item.vendorFlags.vendor_regs or item.vendorFlags.vendor_samuel or item.vendorFlags.vendor_mortimer or item.vendorFlags.vendor_giuseppe or item.vendorFlags.vendor_minerva %}
                            {% if hasVendorFooterIcons or item.canonicalSignals %}
                                <div class="catalog-book-section catalog-book-section-signals">
                                    <div class="item-icons-footer catalog-book-footer">
                                        <div class="catalog-book-footer-signals">
                                            {% if item.vendorFlags.vendor_minerva %}
                                                <span class="catalog-vendor-text-icon" title="{{ 'catalog_books.vendor_minerva'|trans }}">M</span>
                                            {% endif %}
                                            {% if item.vendorFlags.vendor_regs %}
                                                <img src="{{ asset('/assets/icons/Vault79Marker.svg') }}" alt="{{ 'catalog_books.vendor_regs'|trans }}" title="{{ 'catalog_books.vendor_regs'|trans }}">
                                            {% endif %}
                                            {% if item.vendorFlags.vendor_samuel %}
                                                <img src="{{ asset('/assets/icons/HammerWingMarker.svg') }}" alt="{{ 'catalog_books.vendor_samuel'|trans }}" title="{{ 'catalog_books.vendor_samuel'|trans }}">
                                            {% endif %}
                                            {% if item.vendorFlags.vendor_mortimer %}
                                                <img src="{{ asset('/assets/icons/SkullRingMarker.svg') }}" alt="{{ 'catalog_books.vendor_mortimer'|trans }}" title="{{ 'catalog_books.vendor_mortimer'|trans }}">
                                            {% endif %}
                                            {% if item.vendorFlags.vendor_giuseppe %}
                                                <img src="{{ asset('/assets/icons/WhitespringResortMarker.svg') }}" alt="{{ 'catalog_books.vendor_giuseppe'|trans }}" title="{{ 'catalog_books.vendor_giuseppe'|trans }}">
                                            {% endif %}
                                            {% for signal in item.canonicalSignals %}
                                                {% if signalIconMap[signal.field] is defined %}
                                                    <img
                                                        src="{{ asset(signalIconMap[signal.field]) }}"
                                                        alt="{{ signal.label }}"
                                                        title="{{ signal.label }}"
                                                        class="{% if signal.field == 'random_encounters' %}catalog-icon-random-encounter{% endif %}"
                                                    >
                                                {% else %}
                                                    <span class="item-pill">
                                                        {{ signal.label }}
                                                    </span>
                                                {% endif %}
                                            {% endfor %}
                                        </div>
                                    </div>
                                </div>
                            {% endif %}
                        </article>
                    {% else %}
                        <article class="catalog-panel">
                            <p class="catalog-state">{{ 'catalog_books.empty'|trans }}</p>
                        </article>
                    {% endfor %}
                </div>

                {% if totalPages > 1 %}
                    <nav class="catalog-pagination" aria-label="{{ 'catalog_books.pagination'|trans }}">
                        {% if page > 1 %}
                            <a
                                class="catalog-pagination-link"
                                href="{{ path('app_book_catalog', {
                                    _locale: app.request.locale,
                                    q: query ?: null,
                                    lists: selectedLists,
                                    kinds: selectedKinds,
                                    vendorFilters: selectedVendorFilters,
                                    categories: selectedCategories,
                                    subcategories: selectedSubcategories,
                                    signals: selectedSignals,
                                    player: selectedPlayerId ?: null,
                                    knowledge: selectedKnowledge,
                                    sort: selectedSort,
                                    perPage: perPage,
                                    page: page - 1
                                }) }}"
                            >
                                {{ 'catalog_books.previous'|trans }}
                            </a>
                        {% else %}
                            <span class="catalog-pagination-link is-disabled">{{ 'catalog_books.previous'|trans }}</span>
                        {% endif %}

                        <span class="catalog-pagination-current">
                            {{ 'catalog_books.page'|trans({'%page%': page, '%total%': totalPages}) }}
                        </span>

                        {% if page < totalPages %}
                            <a
                                class="catalog-pagination-link"
                                href="{{ path('app_book_catalog', {
                                    _locale: app.request.locale,
                                    q: query ?: null,
                                    lists: selectedLists,
                                    kinds: selectedKinds,
                                    vendorFilters: selectedVendorFilters,
                                    categories: selectedCategories,
                                    subcategories: selectedSubcategories,
                                    signals: selectedSignals,
                                    player: selectedPlayerId ?: null,
                                    knowledge: selectedKnowledge,
                                    sort: selectedSort,
                                    perPage: perPage,
                                    page: page + 1
                                }) }}"
                            >
                                {{ 'catalog_books.next'|trans }}
                            </a>
                        {% else %}
                            <span class="catalog-pagination-link is-disabled">{{ 'catalog_books.next'|trans }}</span>
                        {% endif %}
                    </nav>
                {% endif %}
            </section>
        </section>
    </main>
{% endblock %}
