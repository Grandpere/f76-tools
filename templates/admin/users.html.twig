{% extends 'base.html.twig' %}

{% block title %}{{ 'admin_users.page_title'|trans }}{% endblock %}

{% block body %}
    <main class="translations-page">
        <header class="translations-header">
            <form class="header-locale" method="get">
                <img class="header-locale-icon" src="/assets/icons/language.svg" alt="" aria-hidden="true">
                <label for="admin-users-header-locale-select">{{ 'common.language'|trans }}</label>
                <select id="admin-users-header-locale-select" name="locale" onchange="this.form.submit()">
                    <option value="fr" {% if app.request.locale == 'fr' %}selected{% endif %}>🇫🇷 {{ 'common.locale.fr'|trans }}</option>
                    <option value="en" {% if app.request.locale == 'en' %}selected{% endif %}>🇬🇧 {{ 'common.locale.en'|trans }}</option>
                    <option value="de" {% if app.request.locale == 'de' %}selected{% endif %}>🇩🇪 {{ 'common.locale.de'|trans }}</option>
                </select>
            </form>
            <p class="catalog-kicker">{{ 'admin_users.kicker'|trans }}</p>
            <h1>{{ 'admin_users.title'|trans }}</h1>
            <p>
                <a href="{{ path('app_dashboard', { locale: app.request.locale }) }}">{{ 'admin_users.back_to_dashboard'|trans }}</a>
                · <a href="{{ path('app_admin_item_translations', { locale: app.request.locale, target: 'fr' }) }}">{{ 'admin_users.to_translations'|trans }}</a>
            </p>
        </header>

        {% for message in app.flashes('success') %}
            <p class="translations-flash success">{{ message|trans }}</p>
        {% endfor %}
        {% for message in app.flashes('warning') %}
            <p class="translations-flash warning">{{ message|trans }}</p>
        {% endfor %}

        <section class="translations-panel">
            <h2>{{ 'admin_users.list_title'|trans }}</h2>
            <div class="translations-table-wrap">
                <table class="translations-table">
                    <thead>
                    <tr>
                        <th>{{ 'admin_users.email'|trans }}</th>
                        <th>{{ 'admin_users.roles'|trans }}</th>
                        <th>{{ 'admin_users.active'|trans }}</th>
                        <th>{{ 'admin_users.actions'|trans }}</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for user in users %}
                        <tr>
                            <td>{{ user.email }}</td>
                            <td>{{ user.roles|join(', ') }}</td>
                            <td>{% if user.isActive %}{{ 'common.yes'|trans }}{% else %}{{ 'common.no'|trans }}{% endif %}</td>
                            <td>
                                <div style="display:flex; gap:0.35rem; flex-wrap:wrap;">
                                    <form method="post" action="{{ path('app_admin_users_toggle_active', { id: user.id, locale: app.request.locale }) }}">
                                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_users_toggle_active_' ~ user.id) }}">
                                        <button type="submit">{{ 'admin_users.toggle_active'|trans }}</button>
                                    </form>
                                    <form method="post" action="{{ path('app_admin_users_toggle_admin', { id: user.id, locale: app.request.locale }) }}">
                                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_users_toggle_admin_' ~ user.id) }}">
                                        <button type="submit">{{ 'admin_users.toggle_admin'|trans }}</button>
                                    </form>
                                    <form method="post" action="{{ path('app_admin_users_reset_password', { id: user.id, locale: app.request.locale }) }}">
                                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_users_reset_password_' ~ user.id) }}">
                                        <input type="password" name="new_password" placeholder="{{ 'admin_users.new_password'|trans }}" required style="min-width:150px;">
                                        <button type="submit">{{ 'admin_users.reset_password'|trans }}</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4">{{ 'admin_users.no_users'|trans }}</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>
    </main>
{% endblock %}
