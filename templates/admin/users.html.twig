{% extends 'base.html.twig' %}

{% block title %}{{ 'admin_users.page_title'|trans }}{% endblock %}

{% block body %}
    <main class="translations-page">
        {% include 'admin/_page_header.html.twig' with {
            backLabel: 'admin_users.back_to_dashboard',
            localeSelectId: 'admin-users-header-locale-select',
            localeHiddenFields: {
                google: googleFilter,
                q: query
            },
            kicker: 'admin_users.kicker',
            title: 'admin_users.title',
            description: 'admin_users.description'|trans
        } %}

        {% include 'admin/_flashes.html.twig' %}

        <section class="translations-panel">
            <div class="admin-users-summary" aria-live="polite">
                <span class="admin-users-summary-item">{{ 'admin_users.summary_total'|trans({'%count%': totalUsers}) }}</span>
                <span class="admin-users-summary-item">{{ 'admin_users.summary_google_linked'|trans({'%count%': googleLinkedCount}) }}</span>
                <span class="admin-users-summary-item">{{ 'admin_users.summary_google_unlinked'|trans({'%count%': googleUnlinkedCount}) }}</span>
                <span class="admin-users-summary-item">{{ 'admin_users.summary_visible'|trans({'%count%': visibleUsers}) }}</span>
            </div>
            <form method="get" class="translations-filters">
                {% include 'admin/_text_filter_field.html.twig' with {
                    label: 'admin_users.search',
                    name: 'q',
                    fieldValue: query,
                    placeholder: 'admin_users.search_placeholder'
                } %}
                {% include 'admin/_select_filter_field.html.twig' with {
                    label: 'admin_users.google_filter_label',
                    name: 'google',
                    selectedValue: googleFilter,
                    emptyOptionLabel: 'admin_users.google_filter_all',
                    options: [
                        { value: 'linked', label: 'admin_users.google_filter_linked'|trans },
                        { value: 'unlinked', label: 'admin_users.google_filter_unlinked'|trans }
                    ]
                } %}
                {% include 'admin/_filters_common_hidden_fields.html.twig' %}
                <button type="submit">{{ 'admin_users.filter'|trans }}</button>
            </form>
            <p class="catalog-state">{{ 'admin_users.visible_rows'|trans({'%count%': users|length}) }}</p>
            <h2>{{ 'admin_users.list_title'|trans }}</h2>
            <div class="translations-table-wrap">
                <table class="translations-table admin-users-table">
                    <thead>
                    <tr>
                        <th>{{ 'admin_users.email'|trans }}</th>
                        <th>{{ 'admin_users.roles'|trans }}</th>
                        <th>{{ 'admin_users.active'|trans }}</th>
                        <th>{{ 'admin_users.identities'|trans }}</th>
                        <th>{{ 'admin_users.actions'|trans }}</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for user in users %}
                        <tr>
                            <td>{{ user.email }}</td>
                            <td>{{ user.roles|join(', ') }}</td>
                            <td>{% if user.isActive %}{{ 'common.yes'|trans }}{% else %}{{ 'common.no'|trans }}{% endif %}</td>
                            <td>
                                {% set googleIdentity = googleIdentitiesByUserId[user.id]|default(null) %}
                                {% set isGoogleLinked = googleIdentity is not null %}
                                {% if isGoogleLinked and googleIdentity %}
                                    <span class="admin-identity-badge admin-identity-badge-linked">{{ 'admin_users.google_linked_yes'|trans }}</span>
                                    <div class="admin-identity-meta">
                                        {{ 'admin_users.google_linked_since'|trans({'%date%': googleIdentity.createdAt|date('Y-m-d H:i')}) }}
                                    </div>
                                {% else %}
                                    <span class="admin-identity-badge admin-identity-badge-unlinked">{{ 'admin_users.google_linked_no'|trans }}</span>
                                {% endif %}
                            </td>
                            <td>
                                <div class="admin-users-actions">
                                    <form method="post" action="{{ path('app_admin_users_toggle_active', { id: user.id, locale: app.request.locale }) }}">
                                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_users_toggle_active_' ~ user.id) }}">
                                        <input type="hidden" name="google" value="{{ googleFilter }}">
                                        <input type="hidden" name="q" value="{{ query }}">
                                        <button type="submit">{{ 'admin_users.toggle_active'|trans }}</button>
                                    </form>
                                    <form method="post" action="{{ path('app_admin_users_toggle_admin', { id: user.id, locale: app.request.locale }) }}">
                                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_users_toggle_admin_' ~ user.id) }}">
                                        <input type="hidden" name="google" value="{{ googleFilter }}">
                                        <input type="hidden" name="q" value="{{ query }}">
                                        <button type="submit">{{ 'admin_users.toggle_admin'|trans }}</button>
                                    </form>
                                    <form method="post" action="{{ path('app_admin_users_generate_reset_link', { id: user.id, locale: app.request.locale }) }}">
                                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_users_generate_reset_link_' ~ user.id) }}">
                                        <input type="hidden" name="google" value="{{ googleFilter }}">
                                        <input type="hidden" name="q" value="{{ query }}">
                                        <button type="submit">{{ 'admin_users.generate_reset_link'|trans }}</button>
                                    </form>
                                    {% if isGoogleLinked %}
                                        <form method="post" action="{{ path('app_admin_users_unlink_google', { id: user.id, locale: app.request.locale }) }}">
                                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_users_unlink_google_' ~ user.id) }}">
                                            <input type="hidden" name="google" value="{{ googleFilter }}">
                                            <input type="hidden" name="q" value="{{ query }}">
                                            <button type="submit">{{ 'admin_users.unlink_google'|trans }}</button>
                                        </form>
                                    {% endif %}
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5">{{ 'admin_users.no_users'|trans }}</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>
    </main>
{% endblock %}
