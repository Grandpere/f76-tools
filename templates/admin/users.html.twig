{% extends 'base.html.twig' %}

{% block title %}{{ 'admin_users.page_title'|trans }}{% endblock %}

{% block body %}
    <main class="translations-page">
        {% include 'admin/_page_header.html.twig' with {
            backLabel: 'admin_users.back_to_dashboard',
            localeSelectId: 'admin-users-header-locale-select',
            localeHiddenFields: {
                google: googleFilter,
                active: activeFilter,
                role: roleFilter,
                verified: verifiedFilter,
                localPassword: localPasswordFilter,
                createdFrom: createdFrom ?: null,
                createdTo: createdTo ?: null,
                q: query ?: null,
                sort: sort,
                dir: dir,
                perPage: perPage,
                page: page
            },
            kicker: 'admin_users.kicker',
            title: 'admin_users.title',
            description: 'admin_users.description'|trans
        } %}

        {% include 'admin/_flashes.html.twig' %}

        <section class="translations-panel">
            <div class="admin-users-summary" aria-live="polite">
                <span class="admin-users-summary-item">{{ 'admin_users.summary_total_label'|trans }}: {{ totalUsers }}</span>
                <span class="admin-users-summary-item">{{ 'admin_users.summary_google_linked_label'|trans }}: {{ googleLinkedCount }}</span>
                <span class="admin-users-summary-item">{{ 'admin_users.summary_google_unlinked_label'|trans }}: {{ googleUnlinkedCount }}</span>
                <span class="admin-users-summary-item">{{ 'admin_users.summary_visible_label'|trans }}: {{ visibleUsers }}</span>
            </div>
            {% set commonParams = {
                locale: app.request.locale,
                q: query ?: null,
                google: googleFilter ?: null,
                active: activeFilter ?: null,
                role: roleFilter ?: null,
                verified: verifiedFilter ?: null,
                localPassword: localPasswordFilter ?: null,
                createdFrom: createdFrom ?: null,
                createdTo: createdTo ?: null,
                sort: sort,
                dir: dir,
                perPage: perPage,
                page: page
            } %}
            <form method="get" class="translations-filters">
                {% include 'admin/_text_filter_field.html.twig' with {
                    label: 'admin_users.search',
                    name: 'q',
                    fieldValue: query,
                    placeholder: 'admin_users.search_placeholder'
                } %}
                {% include 'admin/_select_filter_field.html.twig' with {
                    label: 'admin_users.google_filter_label',
                    name: 'google',
                    selectedValue: googleFilter,
                    emptyOptionLabel: 'admin_users.google_filter_all',
                    options: [
                        { value: 'linked', label: 'admin_users.google_filter_linked'|trans },
                        { value: 'unlinked', label: 'admin_users.google_filter_unlinked'|trans }
                    ]
                } %}
                {% include 'admin/_select_filter_field.html.twig' with {
                    label: 'admin_users.active_filter_label',
                    name: 'active',
                    selectedValue: activeFilter,
                    emptyOptionLabel: 'admin_users.active_filter_all',
                    options: [
                        { value: 'active', label: 'admin_users.active_filter_active'|trans },
                        { value: 'inactive', label: 'admin_users.active_filter_inactive'|trans }
                    ]
                } %}
                {% include 'admin/_select_filter_field.html.twig' with {
                    label: 'admin_users.role_filter_label',
                    name: 'role',
                    selectedValue: roleFilter,
                    emptyOptionLabel: 'admin_users.role_filter_all',
                    options: [
                        { value: 'admin', label: 'admin_users.role_filter_admin'|trans },
                        { value: 'user', label: 'admin_users.role_filter_user'|trans }
                    ]
                } %}
                {% include 'admin/_select_filter_field.html.twig' with {
                    label: 'admin_users.verified_filter_label',
                    name: 'verified',
                    selectedValue: verifiedFilter,
                    emptyOptionLabel: 'admin_users.verified_filter_all',
                    options: [
                        { value: 'verified', label: 'admin_users.verified_filter_verified'|trans },
                        { value: 'unverified', label: 'admin_users.verified_filter_unverified'|trans }
                    ]
                } %}
                {% include 'admin/_select_filter_field.html.twig' with {
                    label: 'admin_users.local_password_filter_label',
                    name: 'localPassword',
                    selectedValue: localPasswordFilter,
                    emptyOptionLabel: 'admin_users.local_password_filter_all',
                    options: [
                        { value: 'enabled', label: 'admin_users.local_password_filter_enabled'|trans },
                        { value: 'disabled', label: 'admin_users.local_password_filter_disabled'|trans }
                    ]
                } %}
                <label class="field">
                    <span>{{ 'admin_users.created_from_label'|trans }}</span>
                    <input type="date" name="createdFrom" value="{{ createdFrom }}">
                </label>
                <label class="field">
                    <span>{{ 'admin_users.created_to_label'|trans }}</span>
                    <input type="date" name="createdTo" value="{{ createdTo }}">
                </label>
                {% include 'admin/_per_page_field.html.twig' with {
                    label: 'admin_users.per_page',
                    perPage: perPage,
                    options: [20, 30, 50, 100]
                } %}
                {% include 'admin/_filters_common_hidden_fields.html.twig' %}
                <input type="hidden" name="sort" value="{{ sort }}">
                <input type="hidden" name="dir" value="{{ dir }}">
                <button type="submit">{{ 'admin_users.filter'|trans }}</button>
                <a class="admin-export-link" href="{{ path('app_admin_users_export_csv', commonParams|merge({ page: 1 })) }}">{{ 'admin_users.export_csv'|trans }}</a>
            </form>
            <p class="catalog-state">{{ 'admin_users.visible_rows'|trans({'%count%': visibleUsers}) }}</p>
            {% set previousUrl = page > 1 ? path('app_admin_users', commonParams|merge({ page: page - 1 })) : null %}
            {% set nextUrl = page < totalPages ? path('app_admin_users', commonParams|merge({ page: page + 1 })) : null %}
            {% include 'admin/_pager.html.twig' with {
                page: page,
                totalPages: totalPages,
                previousUrl: previousUrl,
                nextUrl: nextUrl
            } %}
            <h2>{{ 'admin_users.list_title'|trans }}</h2>
            <div class="translations-table-wrap">
                <table class="translations-table admin-users-table">
                    <thead>
                    <tr>
                        {% set emailDir = sort == 'email' and dir == 'asc' ? 'desc' : 'asc' %}
                        {% set createdAtDir = sort == 'createdat' and dir == 'asc' ? 'desc' : 'asc' %}
                        {% set activeDir = sort == 'active' and dir == 'asc' ? 'desc' : 'asc' %}
                        {% set emailAriaSort = sort == 'email' ? (dir == 'asc' ? 'ascending' : 'descending') : 'none' %}
                        {% set createdAtAriaSort = sort == 'createdat' ? (dir == 'asc' ? 'ascending' : 'descending') : 'none' %}
                        {% set activeAriaSort = sort == 'active' ? (dir == 'asc' ? 'ascending' : 'descending') : 'none' %}
                        <th aria-sort="{{ emailAriaSort }}">
                            <a class="admin-sort-link" href="{{ path('app_admin_users', commonParams|merge({ sort: 'email', dir: emailDir, page: 1 })) }}">
                                {{ 'admin_users.email'|trans }}
                                {% if sort == 'email' %}
                                    <span class="admin-sort-indicator" aria-hidden="true">{{ dir == 'asc' ? '▲' : '▼' }}</span>
                                {% endif %}
                            </a>
                        </th>
                        <th aria-sort="{{ createdAtAriaSort }}">
                            <a class="admin-sort-link" href="{{ path('app_admin_users', commonParams|merge({ sort: 'createdat', dir: createdAtDir, page: 1 })) }}">
                                {{ 'admin_users.created_at'|trans }}
                                {% if sort == 'createdat' %}
                                    <span class="admin-sort-indicator" aria-hidden="true">{{ dir == 'asc' ? '▲' : '▼' }}</span>
                                {% endif %}
                            </a>
                        </th>
                        <th>{{ 'admin_users.roles'|trans }}</th>
                        <th aria-sort="{{ activeAriaSort }}">
                            <a class="admin-sort-link" href="{{ path('app_admin_users', commonParams|merge({ sort: 'active', dir: activeDir, page: 1 })) }}">
                                {{ 'admin_users.active'|trans }}
                                {% if sort == 'active' %}
                                    <span class="admin-sort-indicator" aria-hidden="true">{{ dir == 'asc' ? '▲' : '▼' }}</span>
                                {% endif %}
                            </a>
                        </th>
                        <th>{{ 'admin_users.security'|trans }}</th>
                        <th>{{ 'admin_users.identities'|trans }}</th>
                        <th>{{ 'admin_users.actions'|trans }}</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for user in users %}
                        <tr>
                            <td>{{ user.email }}</td>
                            <td>{{ user.createdAt|date('Y-m-d H:i') }}</td>
                            <td>{{ user.roles|join(', ') }}</td>
                            <td>{% if user.isActive %}{{ 'common.yes'|trans }}{% else %}{{ 'common.no'|trans }}{% endif %}</td>
                            <td>
                                {% if user.isEmailVerified %}
                                    <span class="admin-security-badge admin-security-badge-ok">{{ 'admin_users.security_email_verified_yes'|trans }}</span>
                                {% else %}
                                    <span class="admin-security-badge admin-security-badge-warn">{{ 'admin_users.security_email_verified_no'|trans }}</span>
                                {% endif %}
                                {% if user.hasLocalPassword %}
                                    <span class="admin-security-badge admin-security-badge-ok">{{ 'admin_users.security_local_login_yes'|trans }}</span>
                                {% else %}
                                    <span class="admin-security-badge admin-security-badge-warn">{{ 'admin_users.security_local_login_no'|trans }}</span>
                                {% endif %}
                            </td>
                            <td>
                                {% set googleIdentity = googleIdentitiesByUserId[user.id]|default(null) %}
                                {% set isGoogleLinked = googleIdentity is not null %}
                                {% if isGoogleLinked and googleIdentity %}
                                    <span class="admin-identity-badge admin-identity-badge-linked">{{ 'admin_users.google_linked_yes'|trans }}</span>
                                    <div class="admin-identity-meta">
                                        {{ 'admin_users.google_linked_since'|trans({'%date%': googleIdentity.createdAt|date('Y-m-d H:i')}) }}
                                    </div>
                                {% else %}
                                    <span class="admin-identity-badge admin-identity-badge-unlinked">{{ 'admin_users.google_linked_no'|trans }}</span>
                                {% endif %}
                            </td>
                            <td>
                                <div class="admin-users-actions">
                                    <form method="post" action="{{ path('app_admin_users_toggle_active', { id: user.id, locale: app.request.locale }) }}">
                                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_users_toggle_active_' ~ user.id) }}">
                                        <input type="hidden" name="google" value="{{ googleFilter }}">
                                        <input type="hidden" name="active" value="{{ activeFilter }}">
                                        <input type="hidden" name="role" value="{{ roleFilter }}">
                                        <input type="hidden" name="verified" value="{{ verifiedFilter }}">
                                        <input type="hidden" name="localPassword" value="{{ localPasswordFilter }}">
                                        <input type="hidden" name="createdFrom" value="{{ createdFrom }}">
                                        <input type="hidden" name="createdTo" value="{{ createdTo }}">
                                        <input type="hidden" name="q" value="{{ query }}">
                                        <input type="hidden" name="perPage" value="{{ perPage }}">
                                        <input type="hidden" name="sort" value="{{ sort }}">
                                        <input type="hidden" name="dir" value="{{ dir }}">
                                        <input type="hidden" name="page" value="{{ page }}">
                                        <button type="submit">{{ 'admin_users.toggle_active'|trans }}</button>
                                    </form>
                                    <form method="post" action="{{ path('app_admin_users_toggle_admin', { id: user.id, locale: app.request.locale }) }}">
                                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_users_toggle_admin_' ~ user.id) }}">
                                        <input type="hidden" name="google" value="{{ googleFilter }}">
                                        <input type="hidden" name="active" value="{{ activeFilter }}">
                                        <input type="hidden" name="role" value="{{ roleFilter }}">
                                        <input type="hidden" name="verified" value="{{ verifiedFilter }}">
                                        <input type="hidden" name="localPassword" value="{{ localPasswordFilter }}">
                                        <input type="hidden" name="createdFrom" value="{{ createdFrom }}">
                                        <input type="hidden" name="createdTo" value="{{ createdTo }}">
                                        <input type="hidden" name="q" value="{{ query }}">
                                        <input type="hidden" name="perPage" value="{{ perPage }}">
                                        <input type="hidden" name="sort" value="{{ sort }}">
                                        <input type="hidden" name="dir" value="{{ dir }}">
                                        <input type="hidden" name="page" value="{{ page }}">
                                        <button type="submit">{{ 'admin_users.toggle_admin'|trans }}</button>
                                    </form>
                                    <form method="post" action="{{ path('app_admin_users_generate_reset_link', { id: user.id, locale: app.request.locale }) }}">
                                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_users_generate_reset_link_' ~ user.id) }}">
                                        <input type="hidden" name="google" value="{{ googleFilter }}">
                                        <input type="hidden" name="active" value="{{ activeFilter }}">
                                        <input type="hidden" name="role" value="{{ roleFilter }}">
                                        <input type="hidden" name="verified" value="{{ verifiedFilter }}">
                                        <input type="hidden" name="localPassword" value="{{ localPasswordFilter }}">
                                        <input type="hidden" name="createdFrom" value="{{ createdFrom }}">
                                        <input type="hidden" name="createdTo" value="{{ createdTo }}">
                                        <input type="hidden" name="q" value="{{ query }}">
                                        <input type="hidden" name="perPage" value="{{ perPage }}">
                                        <input type="hidden" name="sort" value="{{ sort }}">
                                        <input type="hidden" name="dir" value="{{ dir }}">
                                        <input type="hidden" name="page" value="{{ page }}">
                                        <button type="submit">{{ 'admin_users.generate_reset_link'|trans }}</button>
                                    </form>
                                    {% if not user.isEmailVerified %}
                                        <form method="post" action="{{ path('app_admin_users_force_verify_email', { id: user.id, locale: app.request.locale }) }}">
                                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_users_force_verify_email_' ~ user.id) }}">
                                            <input type="hidden" name="google" value="{{ googleFilter }}">
                                            <input type="hidden" name="active" value="{{ activeFilter }}">
                                            <input type="hidden" name="role" value="{{ roleFilter }}">
                                            <input type="hidden" name="verified" value="{{ verifiedFilter }}">
                                            <input type="hidden" name="localPassword" value="{{ localPasswordFilter }}">
                                            <input type="hidden" name="createdFrom" value="{{ createdFrom }}">
                                            <input type="hidden" name="createdTo" value="{{ createdTo }}">
                                            <input type="hidden" name="q" value="{{ query }}">
                                            <input type="hidden" name="perPage" value="{{ perPage }}">
                                            <input type="hidden" name="sort" value="{{ sort }}">
                                            <input type="hidden" name="dir" value="{{ dir }}">
                                            <input type="hidden" name="page" value="{{ page }}">
                                            <button type="submit">{{ 'admin_users.force_verify_email'|trans }}</button>
                                        </form>
                                        <form method="post" action="{{ path('app_admin_users_resend_verification', { id: user.id, locale: app.request.locale }) }}">
                                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_users_resend_verification_' ~ user.id) }}">
                                            <input type="hidden" name="google" value="{{ googleFilter }}">
                                            <input type="hidden" name="active" value="{{ activeFilter }}">
                                            <input type="hidden" name="role" value="{{ roleFilter }}">
                                            <input type="hidden" name="verified" value="{{ verifiedFilter }}">
                                            <input type="hidden" name="localPassword" value="{{ localPasswordFilter }}">
                                            <input type="hidden" name="createdFrom" value="{{ createdFrom }}">
                                            <input type="hidden" name="createdTo" value="{{ createdTo }}">
                                            <input type="hidden" name="q" value="{{ query }}">
                                            <input type="hidden" name="perPage" value="{{ perPage }}">
                                            <input type="hidden" name="sort" value="{{ sort }}">
                                            <input type="hidden" name="dir" value="{{ dir }}">
                                            <input type="hidden" name="page" value="{{ page }}">
                                            <button type="submit">{{ 'admin_users.resend_verification'|trans }}</button>
                                        </form>
                                    {% endif %}
                                    {% if isGoogleLinked %}
                                        <form method="post" action="{{ path('app_admin_users_unlink_google', { id: user.id, locale: app.request.locale }) }}">
                                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_users_unlink_google_' ~ user.id) }}">
                                            <input type="hidden" name="google" value="{{ googleFilter }}">
                                            <input type="hidden" name="active" value="{{ activeFilter }}">
                                            <input type="hidden" name="role" value="{{ roleFilter }}">
                                            <input type="hidden" name="verified" value="{{ verifiedFilter }}">
                                            <input type="hidden" name="localPassword" value="{{ localPasswordFilter }}">
                                            <input type="hidden" name="createdFrom" value="{{ createdFrom }}">
                                            <input type="hidden" name="createdTo" value="{{ createdTo }}">
                                            <input type="hidden" name="q" value="{{ query }}">
                                            <input type="hidden" name="perPage" value="{{ perPage }}">
                                            <input type="hidden" name="sort" value="{{ sort }}">
                                            <input type="hidden" name="dir" value="{{ dir }}">
                                            <input type="hidden" name="page" value="{{ page }}">
                                            <button
                                                type="submit"
                                                {% if not user.hasLocalPassword %}disabled title="{{ 'admin_users.unlink_google_disabled_reason'|trans }}"{% endif %}
                                            >{{ 'admin_users.unlink_google'|trans }}</button>
                                        </form>
                                        {% if not user.hasLocalPassword %}
                                            <p class="admin-users-actions-help">{{ 'admin_users.unlink_google_disabled_reason'|trans }}</p>
                                        {% endif %}
                                    {% endif %}
                                    <a class="admin-users-action-link" href="{{ path('app_admin_users_auth_events', commonParams|merge({ id: user.id })) }}">{{ 'admin_users.auth_events'|trans }}</a>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="7">{{ 'admin_users.no_users'|trans }}</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>
    </main>
{% endblock %}
