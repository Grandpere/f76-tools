{% extends 'base.html.twig' %}

{% block title %}{{ 'admin_audit.page_title'|trans }}{% endblock %}

{% block body %}
    <main class="translations-page">
        {% include 'admin/_page_header.html.twig' with {
            backLabel: 'admin_audit.back_to_dashboard',
            localeSelectId: 'admin-audit-header-locale-select',
            localeHiddenFields: {
                q: query,
                action: action,
                perPage: perPage,
                page: page
            },
            kicker: 'admin_audit.kicker',
            title: 'admin_audit.title',
            description: 'admin_audit.description'|trans
        } %}

        <section class="translations-panel">
            <form method="get" class="translations-filters">
                {% include 'admin/_text_filter_field.html.twig' with {
                    label: 'admin_audit.search',
                    name: 'q',
                    fieldValue: query,
                    placeholder: 'admin_audit.search_placeholder'
                } %}
                {% include 'admin/_select_filter_field.html.twig' with {
                    label: 'admin_audit.action',
                    name: 'action',
                    selectedValue: action,
                    emptyOptionLabel: 'admin_audit.any_action',
                    options: actions
                } %}
                {% include 'admin/_per_page_field.html.twig' with {
                    label: 'admin_audit.per_page',
                    perPage: perPage,
                    options: [20, 30, 50, 100]
                } %}
                {% include 'admin/_filters_common_hidden_fields.html.twig' %}
                <button type="submit">{{ 'admin_audit.filter'|trans }}</button>
                <a href="{{ path('app_admin_audit_logs_export', { _locale: app.request.locale, q: query ?: null, action: action ?: null }) }}">{{ 'admin_audit.export_csv'|trans }}</a>
            </form>
            <p class="catalog-state">{{ 'admin_audit.visible_rows'|trans({'%count%': totalRows}) }}</p>

            {% set previousUrl = page > 1 ? path('app_admin_audit_logs', { _locale: app.request.locale, q: query ?: null, action: action ?: null, perPage: perPage, page: page - 1 }) : null %}
            {% set nextUrl = page < totalPages ? path('app_admin_audit_logs', { _locale: app.request.locale, q: query ?: null, action: action ?: null, perPage: perPage, page: page + 1 }) : null %}
            {% include 'admin/_pager.html.twig' with {
                page: page,
                totalPages: totalPages,
                previousUrl: previousUrl,
                nextUrl: nextUrl
            } %}

            <div class="translations-table-wrap">
                <table class="translations-table">
                    <thead>
                    <tr>
                        <th>{{ 'admin_audit.when'|trans }}</th>
                        <th>{{ 'admin_audit.action'|trans }}</th>
                        <th>{{ 'admin_audit.actor'|trans }}</th>
                        <th>{{ 'admin_audit.target'|trans }}</th>
                        <th>{{ 'admin_audit.context'|trans }}</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for row in rows %}
                        <tr>
                            <td>{{ row.occurredAt|date('Y-m-d H:i:s') }}</td>
                            <td><code>{{ row.action }}</code></td>
                            <td>{{ row.actorUser.email }}</td>
                            <td>{{ row.targetUser ? row.targetUser.email : '-' }}</td>
                            <td>
                                {% if row.context %}
                                    <code>{{ row.context|json_encode(constant('JSON_UNESCAPED_SLASHES')) }}</code>
                                {% else %}
                                    -
                                {% endif %}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5">{{ 'admin_audit.no_entries'|trans }}</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>
    </main>
{% endblock %}
