{% extends 'base.html.twig' %}

{% block title %}{{ 'admin_roadmap.page_title'|trans }}{% endblock %}

{% block body %}
    <main class="translations-page">
        {% include 'admin/_page_header.html.twig' with {
            backLabel: 'admin_roadmap.back_to_dashboard',
            localeSelectId: 'admin-roadmap-header-locale-select',
            kicker: 'admin_roadmap.kicker',
            title: 'admin_roadmap.title',
            description: 'admin_roadmap.description'|trans,
            activeNav: 'roadmap'
        } %}

        {% include 'admin/_flashes.html.twig' %}
        <section class="translations-panel">
            <h2 class="roadmap-step-title">
                <span class="roadmap-step-badge">1</span>
                <span>{{ 'admin_roadmap.snapshots_title'|trans }}</span>
            </h2>
            <div class="roadmap-import-grid">
                <section class="roadmap-import-card" data-controller="roadmap-json-prompt" data-roadmap-json-prompt-copied-label-value="{{ 'admin_roadmap.json_prompt_copied'|trans }}">
                    <h3 class="roadmap-import-title">{{ 'admin_roadmap.import_json_title'|trans }}</h3>
                    {% set extractorLink = '<a href="https://github.com/Grandpere/f76-roadmap-extractor" target="_blank" rel="noopener noreferrer">F76-roadmap-extractor</a>' %}
                    {% set claudeLink = '<a href="https://claude.ai/" target="_blank" rel="noopener noreferrer">claude.ai</a>' %}
                    <p class="catalog-note info-note roadmap-json-prompt-note">
                        <span class="info-note-content">{{ 'admin_roadmap.json_prompt_hint'|trans({
                                '%extractor_link%': extractorLink,
                                '%claude_link%': claudeLink
                            })|raw }}</span>
                        <button type="button" class="roadmap-json-prompt-open" data-action="roadmap-json-prompt#open">
                            {{ 'admin_roadmap.json_prompt_open'|trans }}
                        </button>
                    </p>
                    <form method="post" action="{{ path('app_admin_roadmap_snapshot_import_json', { _locale: app.request.locale }) }}" enctype="multipart/form-data" class="translations-filters minerva-admin-filters roadmap-upload-form roadmap-upload-form--stack">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_roadmap_snapshot_import_json') }}">
                        <label class="field">
                            {{ 'admin_roadmap.upload_locale'|trans }}
                            <select name="locale" required>
                                {% include '_locale_options.html.twig' with { selectedLocale: app.request.locale } %}
                            </select>
                        </label>
                        <label class="field">
                            {{ 'admin_roadmap.json_season_number'|trans }}
                            <input type="number" name="season_number" min="1" step="1" placeholder="24">
                        </label>
                        <label class="field field--full">
                            {{ 'admin_roadmap.json_image_optional'|trans }}
                            <input type="file" name="image" accept="image/*">
                        </label>
                        <label class="field field--full">
                            {{ 'admin_roadmap.json_payload'|trans }}
                            <textarea class="roadmap-raw-text" name="json_payload" rows="8" placeholder='{"season":24,"events":[{"date_start":"2026-03-03","date_end":"2026-03-10","title":"Bigfoot&apos;s Bash"}]}' required></textarea>
                        </label>
                        <button type="submit">{{ 'admin_roadmap.json_submit'|trans }}</button>
                    </form>
                    <div class="roadmap-json-prompt-modal" data-roadmap-json-prompt-target="modal" data-action="click->roadmap-json-prompt#backdropClose" hidden>
                        <div class="roadmap-json-prompt-dialog" role="dialog" aria-modal="true" aria-labelledby="roadmap-json-prompt-title">
                            <h4 id="roadmap-json-prompt-title">{{ 'admin_roadmap.json_prompt_title'|trans }}</h4>
                            <textarea class="roadmap-json-prompt-textarea" readonly data-roadmap-json-prompt-target="prompt">Tu es un extracteur de données de calendrier. Analyse cette image et extrais tous les événements visibles.
Retourne :

1/ Un tableau markdown avec les colonnes : Date début | Date fin | Événement
2/ Un bloc JSON avec ce format exact, sans texte autour :

json{
  "season": &lt;numéro&gt;,
  "name": "&lt;nom de la saison&gt;",
  "events": [
    {"date_start": "YYYY-MM-DD", "date_end": "YYYY-MM-DD", "title": "&lt;titre exact&gt;"}
  ]
}
Règles :
- Dates au format ISO 8601
- Si une date de fin chevauche le mois suivant, déduis l'année correctement
- Si les dates exactes d'un événement ne sont pas précisées, note-le dans le titre entre parenthèses
- Conserve les titres dans la langue d'origine de l'image
- Trie les événements par date_start croissante</textarea>
                            <div class="roadmap-json-prompt-actions">
                                <button type="button" class="roadmap-json-prompt-button" data-action="roadmap-json-prompt#copy">{{ 'admin_roadmap.json_prompt_copy'|trans }}</button>
                                <button type="button" class="roadmap-json-prompt-close" data-action="roadmap-json-prompt#close">{{ 'admin_roadmap.json_prompt_close'|trans }}</button>
                            </div>
                        </div>
                    </div>
                    <div class="roadmap-json-prompt-toast" data-roadmap-json-prompt-target="toast" hidden></div>
                </section>
            </div>
            <form method="get" class="translations-filters minerva-admin-filters roadmap-season-filter-form">
                {% if selectedSnapshot %}
                    <input type="hidden" name="snapshot" value="{{ selectedSnapshot.id }}">
                {% endif %}
                <label class="field">
                    {{ 'admin_roadmap.snapshot_season'|trans }}
                    <select name="season">
                        <option value="">--</option>
                        {% for season in seasons %}
                            {% set seasonStatusKey = season.isActive
                                ? 'admin_roadmap.season_status_active'
                                : ((season.endsAt and season.endsAt < date()) ? 'admin_roadmap.season_status_finished' : 'admin_roadmap.season_status_upcoming')
                            %}
                            <option value="{{ season.id }}" {{ selectedSeason and season.id == selectedSeason.id ? 'selected' : '' }}>
                                #{{ season.seasonNumber }} · {{ seasonStatusKey|trans }}
                            </option>
                        {% endfor %}
                    </select>
                </label>
                <label class="field">
                    {{ 'admin_roadmap.snapshot_quality_filter'|trans }}
                    <select name="quality">
                        <option value="">{{ 'admin_roadmap.snapshot_quality_filter_all'|trans }}</option>
                        <option value="ok" {{ qualityFilter == 'ok' ? 'selected' : '' }}>{{ 'admin_roadmap.snapshot_quality_ok'|trans }}</option>
                        <option value="warn" {{ qualityFilter == 'warn' ? 'selected' : '' }}>{{ 'admin_roadmap.snapshot_quality_warn'|trans }}</option>
                        <option value="error" {{ qualityFilter == 'error' ? 'selected' : '' }}>{{ 'admin_roadmap.snapshot_quality_error'|trans }}</option>
                    </select>
                </label>
                <button type="submit">{{ 'admin_translations.filter'|trans }}</button>
            </form>
            <p class="catalog-note info-note roadmap-section-hint">
                <span class="info-note-content">{{ 'admin_roadmap.step_snapshots_hint'|trans }}</span>
            </p>
            <div class="translations-table-wrap">
                <table class="translations-table roadmap-snapshots-table">
                    <colgroup>
                        <col class="roadmap-snapshots-col-id">
                        <col class="roadmap-snapshots-col-locale">
                        <col class="roadmap-snapshots-col-provider">
                        <col class="roadmap-snapshots-col-provider">
                        <col class="roadmap-snapshots-col-confidence">
                        <col class="roadmap-snapshots-col-status">
                        <col class="roadmap-snapshots-col-quality">
                        <col class="roadmap-snapshots-col-season">
                        <col class="roadmap-snapshots-col-merge">
                        <col class="roadmap-snapshots-col-scanned">
                        <col class="roadmap-snapshots-col-actions">
                    </colgroup>
                    <thead>
                    <tr>
                        <th>{{ 'admin_roadmap.snapshot_id'|trans }}</th>
                        <th>{{ 'admin_roadmap.snapshot_locale'|trans }}</th>
                        <th>{{ 'admin_roadmap.snapshot_provider'|trans }}</th>
                        <th>{{ 'admin_roadmap.snapshot_ocr_status'|trans }}</th>
                        <th>{{ 'admin_roadmap.snapshot_confidence'|trans }}</th>
                        <th>{{ 'admin_roadmap.snapshot_status'|trans }}</th>
                        <th>{{ 'admin_roadmap.snapshot_quality'|trans }}</th>
                        <th>{{ 'admin_roadmap.snapshot_season'|trans }}</th>
                        <th>{{ 'admin_roadmap.snapshot_merge_usage'|trans }}</th>
                        <th>{{ 'admin_roadmap.snapshot_scanned_at'|trans }}</th>
                        <th>{{ 'admin_roadmap.snapshot_actions'|trans }}</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for snapshot in snapshots %}
                        {% set snapshotId = snapshot.id %}
                        <tr>
                            <td>#{{ snapshotId }}</td>
                            <td>{{ snapshot.locale|upper }}</td>
                            <td>{{ snapshot.ocrProvider }}</td>
                            <td>
                                <span class="item-pill">
                                    {{ ('admin_roadmap.ocr_status_' ~ snapshot.ocrProcessingStatus.value)|trans }}
                                </span>
                            </td>
                            <td>{{ (snapshot.ocrConfidence * 100)|number_format(2, '.', ' ') }}%</td>
                            <td><span class="item-pill">{{ ('admin_roadmap.status_' ~ snapshot.status.value)|trans }}</span></td>
                            {% set quality = snapshotQualityById[snapshotId]|default({ level: 'warn', errors: 0, warnings: 0 }) %}
                            <td class="roadmap-quality-cell">
                                <span class="item-pill roadmap-quality-pill roadmap-quality-pill--{{ quality.level }}">
                                    {{ ('admin_roadmap.snapshot_quality_' ~ quality.level)|trans }}
                                </span>
                                {% if quality.errors > 0 or quality.warnings > 0 %}
                                    <small class="roadmap-quality-meta">
                                        {{ quality.errors }}E · {{ quality.warnings }}W
                                    </small>
                                {% endif %}
                            </td>
                            <td>
                                {% if snapshot.season %}
                                    {% set snapshotSeasonStatusKey = snapshot.season.isActive
                                        ? 'admin_roadmap.season_status_active'
                                        : ((snapshot.season.endsAt and snapshot.season.endsAt < date()) ? 'admin_roadmap.season_status_finished' : 'admin_roadmap.season_status_upcoming')
                                    %}
                                    #{{ snapshot.season.seasonNumber }} · {{ snapshotSeasonStatusKey|trans }}
                                {% else %}
                                    —
                                {% endif %}
                            </td>
                            <td>
                                {% if mergedSnapshotIds[snapshotId]|default(false) %}
                                    <span class="item-pill roadmap-merged-pill">{{ 'admin_roadmap.snapshot_used_in_merge'|trans }}</span>
                                {% else %}
                                    —
                                {% endif %}
                            </td>
                            <td>{{ snapshot.scannedAt|date('Y-m-d H:i') }}</td>
                            <td>
                                <div class="translations-actions roadmap-snapshot-actions">
                                    <a href="{{ path('app_admin_roadmap_snapshots', { _locale: app.request.locale, snapshot: snapshotId }) }}">{{ 'admin_roadmap.open'|trans }}</a>
                                    <form method="post" action="{{ path('app_admin_roadmap_snapshot_delete', { _locale: app.request.locale, id: snapshotId }) }}">
                                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_roadmap_snapshot_delete_' ~ snapshotId) }}">
                                        <button type="submit" class="roadmap-danger-button" title="{{ mergedSnapshotIds[snapshotId]|default(false) ? ('admin_roadmap.snapshot_delete_used_hint'|trans) : '' }}">{{ 'admin_roadmap.delete_snapshot'|trans }}</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td class="admin-empty-cell" colspan="11">{{ 'admin_roadmap.empty_snapshots'|trans }}</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
            <p class="catalog-note roadmap-quality-legend">
                {{ 'admin_roadmap.snapshot_quality_legend'|trans }}
            </p>
        </section>

        {% if selectedSnapshot %}
            <section class="translations-panel">
                <h2 class="roadmap-step-title">
                    <span class="roadmap-step-badge">2</span>
                    <span>{{ 'admin_roadmap.selected_snapshot_title'|trans({'%id%': selectedSnapshot.id}) }}</span>
                </h2>
                {% set selectedSnapshotSeasonLabel = selectedSnapshot.season ? ('#' ~ selectedSnapshot.season.seasonNumber) : ('admin_roadmap.snapshot_season_unknown'|trans) %}
                <p class="catalog-state">{{ 'admin_roadmap.selected_snapshot_state'|trans({
                        '%locale%': selectedSnapshot.locale|upper,
                        '%status%': ('admin_roadmap.status_' ~ selectedSnapshot.status.value)|trans,
                        '%season%': selectedSnapshotSeasonLabel
                    }) }}</p>
                <div class="roadmap-review-grid">
                    <article class="roadmap-review-card">
                        <h3>{{ 'admin_roadmap.source_title'|trans }}</h3>
                        {% if selectedSnapshotImageUrl %}
                            <a href="{{ selectedSnapshotImageUrl }}" target="_blank" rel="noopener noreferrer">
                                <img
                                    class="roadmap-source-image"
                                    src="{{ selectedSnapshotImageUrl }}"
                                    alt="{{ 'admin_roadmap.source_image_alt'|trans({'%id%': selectedSnapshot.id}) }}"
                                    loading="lazy"
                                >
                            </a>
                        {% else %}
                            <p class="catalog-state">{{ 'admin_roadmap.source_image_unavailable'|trans }}</p>
                        {% endif %}
                        <dl class="roadmap-meta-list">
                            <div>
                                <dt>{{ 'admin_roadmap.snapshot_locale'|trans }}</dt>
                                <dd>{{ selectedSnapshot.locale|upper }}</dd>
                            </div>
                            <div>
                                <dt>{{ 'admin_roadmap.snapshot_provider'|trans }}</dt>
                                <dd>{{ selectedSnapshot.ocrProvider }}</dd>
                            </div>
                            <div>
                                <dt>{{ 'admin_roadmap.snapshot_ocr_status'|trans }}</dt>
                                <dd>{{ ('admin_roadmap.ocr_status_' ~ selectedSnapshot.ocrProcessingStatus.value)|trans }}</dd>
                            </div>
                            <div>
                                <dt>{{ 'admin_roadmap.snapshot_confidence'|trans }}</dt>
                                <dd>{{ (selectedSnapshot.ocrConfidence * 100)|number_format(2, '.', ' ') }}%</dd>
                            </div>
                            {% if selectedSnapshot.ocrProcessingError %}
                                <div>
                                    <dt>{{ 'admin_roadmap.snapshot_ocr_error'|trans }}</dt>
                                    <dd>{{ selectedSnapshot.ocrProcessingError }}</dd>
                                </div>
                            {% endif %}
                            <div>
                                <dt>{{ 'admin_roadmap.snapshot_scanned_at'|trans }}</dt>
                                <dd>{{ selectedSnapshot.scannedAt|date('Y-m-d H:i') }}</dd>
                            </div>
                            <div>
                                <dt>{{ 'admin_roadmap.events_count'|trans }}</dt>
                                <dd>{{ events|length }}</dd>
                            </div>
                        </dl>
                        {% if selectedSnapshotQuality %}
                            <div class="roadmap-quality-panel">
                                <h4 class="roadmap-attempts-title">{{ 'admin_roadmap.snapshot_quality_details'|trans }}</h4>
                                <p class="roadmap-quality-current">
                                    <span class="item-pill roadmap-quality-pill roadmap-quality-pill--{{ selectedSnapshotQuality.level }}">
                                        {{ ('admin_roadmap.snapshot_quality_' ~ selectedSnapshotQuality.level)|trans }}
                                    </span>
                                </p>
                                {% if selectedSnapshotQuality.errors is not empty %}
                                    <p class="roadmap-quality-list-title">{{ 'admin_roadmap.snapshot_quality_errors'|trans }}</p>
                                    <ul class="roadmap-quality-list roadmap-quality-list--error">
                                        {% for message in selectedSnapshotQuality.errors %}
                                            <li>{{ message }}</li>
                                        {% endfor %}
                                    </ul>
                                {% endif %}
                                {% if selectedSnapshotQuality.warnings is not empty %}
                                    <p class="roadmap-quality-list-title">{{ 'admin_roadmap.snapshot_quality_warnings'|trans }}</p>
                                    <ul class="roadmap-quality-list roadmap-quality-list--warn">
                                        {% for message in selectedSnapshotQuality.warnings %}
                                            <li>{{ message }}</li>
                                        {% endfor %}
                                    </ul>
                                {% endif %}
                            </div>
                        {% endif %}
                        {% if selectedSnapshot.ocrAttemptsSummary %}
                            <h4 class="roadmap-attempts-title">{{ 'admin_roadmap.snapshot_ocr_attempts'|trans }}</h4>
                            <pre class="roadmap-attempts-summary">{{ selectedSnapshot.ocrAttemptsSummary }}</pre>
                        {% endif %}
                    </article>

                    <article class="roadmap-review-card">
                        <h3>{{ 'admin_roadmap.raw_text_title'|trans }}</h3>
                        <form method="post" action="{{ path('app_admin_roadmap_snapshot_raw_text_save', { _locale: app.request.locale, id: selectedSnapshot.id }) }}">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_roadmap_snapshot_raw_text_save_' ~ selectedSnapshot.id) }}">
                            <textarea class="roadmap-raw-text" name="raw_text" rows="16">{{ selectedSnapshot.rawText }}</textarea>
                            <label class="roadmap-generate-toggle">
                                <input type="checkbox" name="generate_events" value="1">
                                <span>{{ 'admin_roadmap.generate_after_save'|trans }}</span>
                            </label>
                            <div class="translations-actions roadmap-inline-actions">
                                <button type="submit">{{ 'admin_roadmap.save_raw_text'|trans }}</button>
                            </div>
                        </form>
                    </article>
                </div>
                <div class="translations-filters roadmap-primary-actions">
                    <form method="post" action="{{ path('app_admin_roadmap_snapshot_approve', { _locale: app.request.locale, id: selectedSnapshot.id }) }}">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_roadmap_snapshot_approve_' ~ selectedSnapshot.id) }}">
                        <button type="submit" class="roadmap-approve-button">{{ 'admin_roadmap.approve_snapshot'|trans }}</button>
                    </form>
                </div>
                <p class="catalog-note info-note roadmap-actions-help">
                    <span class="info-note-content">{{ 'admin_roadmap.actions_help'|trans }}</span>
                </p>
            </section>

            <section class="translations-panel">
                <h2 class="roadmap-step-title">
                    <span class="roadmap-step-badge">3</span>
                    <span>{{ 'admin_roadmap.events_title'|trans }}</span>
                </h2>
                <div class="roadmap-events-header">
                    <span class="roadmap-count-pill">{{ events|length }} {{ 'admin_roadmap.events_count'|trans|lower }}</span>
                </div>
                <form
                    method="post"
                    action="{{ path('app_admin_roadmap_snapshot_events_save', { _locale: app.request.locale, id: selectedSnapshot.id }) }}"
                    data-controller="minerva-admin-datepicker"
                    data-minerva-admin-datepicker-locale-value="{{ app.request.locale }}"
                >
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_roadmap_snapshot_events_save_' ~ selectedSnapshot.id) }}">
                    <div class="translations-table-wrap">
                        <table class="translations-table roadmap-events-table">
                            <colgroup>
                                <col class="roadmap-col-order">
                            <col class="roadmap-col-title">
                            <col class="roadmap-col-start">
                            <col class="roadmap-col-end">
                        </colgroup>
                        <thead>
                        <tr>
                            <th>{{ 'admin_roadmap.event_order'|trans }}</th>
                            <th>{{ 'admin_roadmap.event_title'|trans }}</th>
                            <th>{{ 'admin_roadmap.event_starts_at'|trans }}</th>
                            <th>{{ 'admin_roadmap.event_ends_at'|trans }}</th>
                        </tr>
                        </thead>
                            <tbody>
                            {% for event in events %}
                                {% set eventId = event.id %}
                                <tr>
                                    <td>{{ event.sortOrder }}</td>
                                    <td>
                                        <textarea class="roadmap-input roadmap-title-input" name="events[{{ eventId }}][title]" rows="2" maxlength="255" required>{{ event.title }}</textarea>
                                    </td>
                                    <td>
                                        <input class="roadmap-input" type="datetime-local" name="events[{{ eventId }}][startsAt]" value="{{ event.startsAt|date('Y-m-d\\TH:i') }}" required>
                                    </td>
                                <td>
                                    <input class="roadmap-input" type="datetime-local" name="events[{{ eventId }}][endsAt]" value="{{ event.endsAt|date('Y-m-d\\TH:i') }}" required>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td class="admin-empty-cell" colspan="4">{{ 'admin_roadmap.empty_events'|trans }}</td>
                            </tr>
                        {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    <div class="translations-actions roadmap-sticky-actions">
                        <button type="submit">{{ 'admin_roadmap.save_events'|trans }}</button>
                    </div>
                </form>
            </section>
        {% else %}
            <section class="translations-panel">
                <h2 class="roadmap-step-title">
                    <span class="roadmap-step-badge">2</span>
                    <span>{{ 'admin_roadmap.selected_snapshot_pending_title'|trans }}</span>
                </h2>
                <p class="catalog-note info-note roadmap-actions-help">
                    <span class="info-note-content">{{ 'admin_roadmap.selected_snapshot_pending_hint'|trans }}</span>
                </p>
            </section>
        {% endif %}

        <section class="translations-panel">
            <h2 class="roadmap-step-title">
                <span class="roadmap-step-badge">{{ selectedSnapshot ? '4' : '3' }}</span>
                <span>{{ 'admin_roadmap.canonical_title'|trans }}</span>
            </h2>
            <p class="catalog-note info-note roadmap-section-hint roadmap-canonical-intro">
                <span class="info-note-content">
                    {{ 'admin_roadmap.canonical_description'|trans }}
                    {{ 'admin_roadmap.merge_requires_approved_hint'|trans }}
                    {{ 'admin_roadmap.merge_requires_same_season_hint'|trans }}
                </span>
            </p>
            {% set mergeHasBlockingQuality = false %}
            {% for mergeLocale in ['fr', 'en', 'de'] %}
                {% if mergeSnapshotContext[mergeLocale] and mergeSnapshotContext[mergeLocale].qualityLevel == 'error' %}
                    {% set mergeHasBlockingQuality = true %}
                {% endif %}
            {% endfor %}
            <form method="post" action="{{ path('app_admin_roadmap_merge_locales', { _locale: app.request.locale }) }}" class="translations-filters roadmap-merge-form">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_roadmap_merge_locales') }}">
                <label class="roadmap-merge-field">
                    {{ 'admin_roadmap.merge_fr_snapshot'|trans }}
                    <input type="number" name="fr_snapshot_id" min="1" step="1" value="{{ mergeSnapshotContext.fr ? mergeSnapshotContext.fr.snapshotId : '' }}" required>
                    {% if mergeSnapshotContext.fr %}
                        <small>
                            {% if mergeSnapshotContext.fr.seasonNumber %}
                                {{ 'admin_roadmap.merge_snapshot_context'|trans({'%season%': mergeSnapshotContext.fr.seasonNumber}) }}
                            {% else %}
                                {{ 'admin_roadmap.merge_snapshot_context_missing'|trans }}
                            {% endif %}
                        </small>
                        <small class="roadmap-merge-quality-line">
                            {{ 'admin_roadmap.merge_quality_label'|trans }}:
                            <span class="item-pill roadmap-quality-pill roadmap-quality-pill--{{ mergeSnapshotContext.fr.qualityLevel }}">
                                {{ ('admin_roadmap.snapshot_quality_' ~ mergeSnapshotContext.fr.qualityLevel)|trans }}
                            </span>
                            {{ mergeSnapshotContext.fr.errors }}E · {{ mergeSnapshotContext.fr.warnings }}W
                        </small>
                    {% endif %}
                </label>
                <label class="roadmap-merge-field">
                    {{ 'admin_roadmap.merge_en_snapshot'|trans }}
                    <input type="number" name="en_snapshot_id" min="1" step="1" value="{{ mergeSnapshotContext.en ? mergeSnapshotContext.en.snapshotId : '' }}" required>
                    {% if mergeSnapshotContext.en %}
                        <small>
                            {% if mergeSnapshotContext.en.seasonNumber %}
                                {{ 'admin_roadmap.merge_snapshot_context'|trans({'%season%': mergeSnapshotContext.en.seasonNumber}) }}
                            {% else %}
                                {{ 'admin_roadmap.merge_snapshot_context_missing'|trans }}
                            {% endif %}
                        </small>
                        <small class="roadmap-merge-quality-line">
                            {{ 'admin_roadmap.merge_quality_label'|trans }}:
                            <span class="item-pill roadmap-quality-pill roadmap-quality-pill--{{ mergeSnapshotContext.en.qualityLevel }}">
                                {{ ('admin_roadmap.snapshot_quality_' ~ mergeSnapshotContext.en.qualityLevel)|trans }}
                            </span>
                            {{ mergeSnapshotContext.en.errors }}E · {{ mergeSnapshotContext.en.warnings }}W
                        </small>
                    {% endif %}
                </label>
                <label class="roadmap-merge-field">
                    {{ 'admin_roadmap.merge_de_snapshot'|trans }}
                    <input type="number" name="de_snapshot_id" min="1" step="1" value="{{ mergeSnapshotContext.de ? mergeSnapshotContext.de.snapshotId : '' }}" required>
                    {% if mergeSnapshotContext.de %}
                        <small>
                            {% if mergeSnapshotContext.de.seasonNumber %}
                                {{ 'admin_roadmap.merge_snapshot_context'|trans({'%season%': mergeSnapshotContext.de.seasonNumber}) }}
                            {% else %}
                                {{ 'admin_roadmap.merge_snapshot_context_missing'|trans }}
                            {% endif %}
                        </small>
                        <small class="roadmap-merge-quality-line">
                            {{ 'admin_roadmap.merge_quality_label'|trans }}:
                            <span class="item-pill roadmap-quality-pill roadmap-quality-pill--{{ mergeSnapshotContext.de.qualityLevel }}">
                                {{ ('admin_roadmap.snapshot_quality_' ~ mergeSnapshotContext.de.qualityLevel)|trans }}
                            </span>
                            {{ mergeSnapshotContext.de.errors }}E · {{ mergeSnapshotContext.de.warnings }}W
                        </small>
                    {% endif %}
                </label>
                <label class="roadmap-generate-toggle">
                    <input type="checkbox" name="dry_run" value="1">
                    <span>{{ 'admin_roadmap.merge_dry_run'|trans }}</span>
                </label>
                <button type="submit" {{ mergeHasBlockingQuality ? 'disabled' : '' }}>{{ 'admin_roadmap.merge_submit'|trans }}</button>
            </form>
            {% if mergeHasBlockingQuality %}
                <p class="catalog-note roadmap-merge-blocking-note">{{ 'admin_roadmap.merge_quality_blocking_hint'|trans }}</p>
            {% endif %}
            <div class="translations-table-wrap">
                <table class="translations-table roadmap-canonical-table">
                    <colgroup>
                        <col class="roadmap-canonical-col-season">
                        <col class="roadmap-canonical-col-window">
                        <col class="roadmap-canonical-col-confidence">
                        <col class="roadmap-canonical-col-missing">
                        <col class="roadmap-canonical-col-fr">
                        <col class="roadmap-canonical-col-en">
                        <col class="roadmap-canonical-col-de">
                    </colgroup>
                    <thead>
                    <tr>
                        <th>{{ 'admin_roadmap.snapshot_season'|trans }}</th>
                        <th>{{ 'admin_roadmap.canonical_window'|trans }}</th>
                        <th>{{ 'admin_roadmap.canonical_confidence'|trans }}</th>
                        <th>{{ 'admin_roadmap.canonical_missing_locales'|trans }}</th>
                        <th>FR</th>
                        <th>EN</th>
                        <th>DE</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for row in canonicalRows %}
                        <tr>
                            <td>{{ row.seasonNumber ? ('#' ~ row.seasonNumber) : ('admin_roadmap.snapshot_season_unknown'|trans) }}</td>
                            <td>
                                {{ row.startsAt|date('Y-m-d') }} -> {{ row.endsAt|date('Y-m-d') }}
                            </td>
                            <td>{{ row.confidenceScore }}%</td>
                            <td>
                                {% if row.missingLocales is empty %}
                                    <span class="roadmap-canonical-pill roadmap-canonical-pill-complete">{{ 'admin_roadmap.canonical_complete'|trans }}</span>
                                {% else %}
                                    <span class="roadmap-canonical-pill roadmap-canonical-pill-missing">{{ row.missingLocales|join(', ')|upper }}</span>
                                {% endif %}
                            </td>
                            <td>{{ row.translations.fr ?? '-' }}</td>
                            <td>{{ row.translations.en ?? '-' }}</td>
                            <td>{{ row.translations.de ?? '-' }}</td>
                        </tr>
                    {% else %}
                        <tr>
                            <td class="admin-empty-cell" colspan="7">{{ 'admin_roadmap.canonical_empty'|trans }}</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>
    </main>
{% endblock %}
