{% extends 'base.html.twig' %}

{% block title %}{{ 'admin_catalog.page_title'|trans }}{% endblock %}

{% block body %}
    <main class="translations-page">
        {% include 'admin/_page_header.html.twig' with {
            backLabel: 'admin_catalog.back_to_dashboard',
            localeSelectId: 'admin-header-locale-select',
            localeHiddenFields: {
                type: type,
                mergeStatus: mergeStatus,
                q: query,
                perPage: perPage,
                page: page,
                item: selectedPublicId
            },
            kicker: 'admin_catalog.kicker',
            title: 'admin_catalog.title',
            description: 'admin_catalog.description'|trans,
            activeNav: 'catalog'
        } %}

        <section class="translations-panel admin-catalog-panel">
            <form method="get" class="translations-filters">
                <label class="field">
                    <span>{{ 'admin_catalog.type'|trans }}</span>
                    <select name="type">
                        <option value="">{{ 'admin_catalog.type_all'|trans }}</option>
                        {% for option in typeOptions %}
                            <option value="{{ option.value }}" {% if type == option.value %}selected{% endif %}>{{ option.value }}</option>
                        {% endfor %}
                    </select>
                </label>
                <label class="field">
                    <span>{{ 'admin_catalog.merge_status'|trans }}</span>
                    <select name="mergeStatus">
                        <option value="">{{ 'admin_catalog.merge_status_all'|trans }}</option>
                        {% for option in mergeStatusOptions %}
                            <option value="{{ option }}" {% if mergeStatus == option %}selected{% endif %}>{{ ('admin_catalog.merge_status_' ~ option)|trans }}</option>
                        {% endfor %}
                    </select>
                </label>
                {% include 'admin/_text_filter_field.html.twig' with {
                    label: 'admin_catalog.search',
                    name: 'q',
                    fieldValue: query,
                    placeholder: 'admin_catalog.search_placeholder'
                } %}
                {% include 'admin/_per_page_field.html.twig' with {
                    label: 'admin_catalog.per_page',
                    perPage: perPage,
                    options: [20, 40, 80, 120]
                } %}
                {% include 'admin/_filters_common_hidden_fields.html.twig' %}
                <button type="submit">{{ 'admin_catalog.filter'|trans }}</button>
            </form>

            <p class="catalog-state">{{ 'admin_catalog.visible_rows'|trans({'%count%': totalItems}) }}</p>

            {% set baseParams = {
                _locale: app.request.locale,
                type: type ?: null,
                mergeStatus: mergeStatus ?: null,
                q: query ?: null,
                perPage: perPage,
                item: selectedPublicId
            } %}
            {% set previousUrl = page > 1 ? path('app_admin_catalog_items', baseParams|merge({ page: page - 1 })) : null %}
            {% set nextUrl = page < totalPages ? path('app_admin_catalog_items', baseParams|merge({ page: page + 1 })) : null %}
            {% include 'admin/_pager.html.twig' with {
                page: page,
                totalPages: totalPages,
                previousUrl: previousUrl,
                nextUrl: nextUrl
            } %}

            <div class="translations-table-wrap">
                <table class="translations-table">
                    <caption class="visually-hidden">{{ 'admin_catalog.table_caption'|trans }}</caption>
                    <thead>
                    <tr>
                        <th>{{ 'admin_catalog.item'|trans }}</th>
                        <th>{{ 'admin_catalog.source_id'|trans }}</th>
                        <th>{{ 'admin_catalog.type'|trans }}</th>
                        <th>{{ 'admin_catalog.merge_status'|trans }}</th>
                        <th>{{ 'admin_catalog.providers'|trans }}</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for row in items %}
                        <tr class="{{ selectedPublicId == row.publicId ? 'translations-section-row' : '' }}">
                            <td>
                                <a href="{{ path('app_admin_catalog_items', {
                                    _locale: app.request.locale,
                                    type: type ?: null,
                                    mergeStatus: mergeStatus ?: null,
                                    q: query ?: null,
                                    perPage: perPage,
                                    page: page,
                                    item: row.publicId
                                }) }}">{{ row.name }}</a>
                                <div class="translations-help"><code>{{ row.publicId }}</code></div>
                            </td>
                            <td>{{ row.sourceId }}</td>
                            <td><code>{{ row.type }}</code></td>
                            <td>
                                <div class="admin-catalog-badge-stack">
                                    {% set statusClass = row.mergeStatus == 'material_conflict'
                                        ? 'admin-security-badge-warn'
                                        : (row.mergeStatus == 'aligned' ? 'admin-security-badge-ok' : 'admin-catalog-badge-info') %}
                                    <span class="admin-security-badge {{ statusClass }}">
                                        {{ ('admin_catalog.merge_status_' ~ row.mergeStatus)|trans }}
                                    </span>
                                    {% if row.mergeGenericLabelCount > 0 %}
                                        <span class="item-pill">{{ 'admin_catalog.generic_label_count'|trans({'%count%': row.mergeGenericLabelCount}) }}</span>
                                    {% endif %}
                                    {% if row.mergeSourceIssueCount > 0 %}
                                        <span class="item-pill">{{ 'admin_catalog.source_issue_count'|trans({'%count%': row.mergeSourceIssueCount}) }}</span>
                                    {% endif %}
                                    {% if row.mergeMaterialConflictCount > 0 %}
                                        <span class="item-pill">{{ 'admin_catalog.material_conflict_count'|trans({'%count%': row.mergeMaterialConflictCount}) }}</span>
                                    {% endif %}
                                </div>
                            </td>
                            <td>{{ row.providerSummary }}</td>
                        </tr>
                    {% else %}
                        <tr>
                            <td class="admin-empty-cell" colspan="5">{{ 'admin_catalog.no_items'|trans }}</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>

            <div class="translations-actions">
                <span class="catalog-state">{{ 'admin_catalog.visible_page_rows'|trans({'%count%': pageRows}) }}</span>
            </div>
        </section>

        <section class="translations-panel admin-catalog-panel">
            <h2 class="admin-catalog-section-title">{{ 'admin_catalog.selected_item'|trans }}</h2>

            {% if selectedItem %}
                <p class="catalog-state admin-catalog-selected-headline">{{ selectedItem.name }} · <code>{{ selectedItem.publicId }}</code></p>
                <div class="translations-table-wrap admin-catalog-table-wrap">
                    <table class="translations-table">
                        <tbody>
                        <tr><th>{{ 'admin_catalog.source_id'|trans }}</th><td>{{ selectedItem.sourceId }}</td></tr>
                        <tr><th>{{ 'admin_catalog.type'|trans }}</th><td><code>{{ selectedItem.type }}</code></td></tr>
                        <tr><th>{{ 'admin_catalog.name_key'|trans }}</th><td><code>{{ selectedItem.nameKey }}</code></td></tr>
                        <tr><th>{{ 'admin_catalog.desc_key'|trans }}</th><td>{% if selectedItem.descKey %}<code>{{ selectedItem.descKey }}</code>{% else %}{{ 'admin_catalog.empty'|trans }}{% endif %}</td></tr>
                        <tr><th>{{ 'admin_catalog.note_key'|trans }}</th><td>{% if selectedItem.noteKey %}<code>{{ selectedItem.noteKey }}</code>{% else %}{{ 'admin_catalog.empty'|trans }}{% endif %}</td></tr>
                        <tr><th>{{ 'admin_catalog.price'|trans }}</th><td>{{ selectedItem.price ?? 'admin_catalog.empty'|trans }}</td></tr>
                        <tr><th>{{ 'admin_catalog.price_minerva'|trans }}</th><td>{{ selectedItem.priceMinerva ?? 'admin_catalog.empty'|trans }}</td></tr>
                        <tr><th>{{ 'admin_catalog.rank'|trans }}</th><td>{{ selectedItem.rank ?? 'admin_catalog.empty'|trans }}</td></tr>
                        <tr><th>{{ 'admin_catalog.is_new'|trans }}</th><td>{{ selectedItem.isNew ? 'admin_catalog.yes'|trans : 'admin_catalog.no'|trans }}</td></tr>
                        <tr>
                            <th>{{ 'admin_catalog.book_lists'|trans }}</th>
                            <td>
                                {% if selectedItem.bookLists %}
                                    {% for bookList in selectedItem.bookLists %}
                                        <span>#{{ bookList.listNumber }}{% if bookList.isSpecial %} · {{ 'admin_catalog.special_list'|trans }}{% endif %}</span>{% if not loop.last %}<br>{% endif %}
                                    {% endfor %}
                                {% else %}
                                    {{ 'admin_catalog.empty'|trans }}
                                {% endif %}
                            </td>
                        </tr>
                        <tr>
                            <th>{{ 'admin_catalog.flags'|trans }}</th>
                            <td>
                                {% for label, enabled in selectedItem.flags %}
                                    <code>{{ label }}</code>: {{ enabled ? 'admin_catalog.yes'|trans : 'admin_catalog.no'|trans }}{% if not loop.last %}<br>{% endif %}
                                {% endfor %}
                            </td>
                        </tr>
                        </tbody>
                    </table>
                </div>

                <h3 class="admin-catalog-subtitle">{{ 'admin_catalog.external_sources'|trans }}</h3>
                <div class="translations-table-wrap admin-catalog-table-wrap">
                    <table class="translations-table admin-catalog-detail-table">
                        <thead>
                        <tr>
                            <th>{{ 'admin_catalog.provider'|trans }}</th>
                            <th>{{ 'admin_catalog.external_ref'|trans }}</th>
                            <th>{{ 'admin_catalog.external_url'|trans }}</th>
                            <th>{{ 'admin_catalog.metadata'|trans }}</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for source in selectedItem.externalSources %}
                            <tr>
                                <td><code>{{ source.provider }}</code></td>
                                <td><code>{{ source.externalRef }}</code></td>
                                <td>
                                    {% if source.externalUrl %}
                                        <a class="admin-catalog-link" href="{{ source.externalUrl }}" target="_blank" rel="noreferrer noopener">{{ source.externalUrl }}</a>
                                    {% else %}
                                        {{ 'admin_catalog.empty'|trans }}
                                    {% endif %}
                                </td>
                                <td><pre class="admin-catalog-code-block">{{ source.metadataJson }}</pre></td>
                            </tr>
                        {% else %}
                            <tr>
                                <td class="admin-empty-cell" colspan="4">{{ 'admin_catalog.no_external_sources'|trans }}</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>

                <h3 class="admin-catalog-subtitle">{{ 'admin_catalog.source_merge'|trans }}</h3>
                {% if selectedItem.sourceMerge %}
                    <p class="catalog-state">{{ selectedItem.sourceMerge.label }}</p>
                    <div class="admin-catalog-badge-stack">
                        {% set summary = selectedItem.sourceMerge.summary %}
                        {% set summaryClass = summary.status == 'material_conflict'
                            ? 'admin-security-badge-warn'
                            : (summary.status == 'aligned' ? 'admin-security-badge-ok' : 'admin-catalog-badge-info') %}
                        <span class="admin-security-badge {{ summaryClass }}">
                            {{ ('admin_catalog.merge_status_' ~ summary.status)|trans }}
                        </span>
                        <span class="item-pill">{{ 'admin_catalog.retained_fields_count'|trans({'%count%': summary.retainedFields}) }}</span>
                        {% if summary.genericLabelCount > 0 %}
                            <span class="item-pill">{{ 'admin_catalog.generic_label_count'|trans({'%count%': summary.genericLabelCount}) }}</span>
                        {% endif %}
                        {% if summary.sourceIssueCount > 0 %}
                            <span class="item-pill">{{ 'admin_catalog.source_issue_count'|trans({'%count%': summary.sourceIssueCount}) }}</span>
                        {% endif %}
                        {% if summary.materialConflictCount > 0 %}
                            <span class="item-pill">{{ 'admin_catalog.material_conflict_count'|trans({'%count%': summary.materialConflictCount}) }}</span>
                        {% endif %}
                    </div>
                    <div class="translations-table-wrap admin-catalog-table-wrap">
                        <table class="translations-table admin-catalog-detail-table">
                            <thead>
                            <tr>
                                <th>{{ 'admin_catalog.field'|trans }}</th>
                                <th>{{ 'admin_catalog.provider'|trans }}</th>
                                <th>{{ 'admin_catalog.reason'|trans }}</th>
                                <th>{{ 'admin_catalog.value'|trans }}</th>
                                <th>{{ 'admin_catalog.other_value'|trans }}</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for decision in selectedItem.sourceMerge.decisions %}
                                <tr>
                                    <td><code>{{ decision.field }}</code></td>
                                    <td><code>{{ decision.provider }}</code></td>
                                    <td><code>{{ decision.reason }}</code></td>
                                    <td><pre class="admin-catalog-code-block">{{ decision.value|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre></td>
                                    <td><pre class="admin-catalog-code-block">{{ decision.other_value|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre></td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td class="admin-empty-cell" colspan="5">{{ 'admin_catalog.no_merge_decisions'|trans }}</td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>

                    <h4 class="admin-catalog-subtitle admin-catalog-subtitle-small">{{ 'admin_catalog.canonical_signals'|trans }}</h4>
                    <div class="translations-table-wrap admin-catalog-table-wrap">
                        <table class="translations-table admin-catalog-detail-table">
                            <thead>
                            <tr>
                                <th>{{ 'admin_catalog.field'|trans }}</th>
                                <th>{{ 'admin_catalog.provider'|trans }}</th>
                                <th>{{ 'admin_catalog.value'|trans }}</th>
                                <th>{{ 'admin_catalog.reason'|trans }}</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for signal in selectedItem.canonicalSignals %}
                                <tr>
                                    <td>
                                        {% set fieldKey = 'admin_catalog.canonical_field_' ~ signal.field %}
                                        {{ fieldKey|trans({}, 'messages') == fieldKey ? signal.field : fieldKey|trans }}
                                    </td>
                                    <td><code>{{ signal.provider }}</code></td>
                                    <td><pre class="admin-catalog-code-block">{{ signal.value|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre></td>
                                    <td><code>{{ signal.reason }}</code></td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td class="admin-empty-cell" colspan="4">{{ 'admin_catalog.no_canonical_signals'|trans }}</td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>

                    <h4 class="admin-catalog-subtitle admin-catalog-subtitle-small">{{ 'admin_catalog.merge_conflicts'|trans }}</h4>
                    <div class="translations-table-wrap admin-catalog-table-wrap">
                        <table class="translations-table admin-catalog-detail-table">
                            <thead>
                            <tr>
                                <th>{{ 'admin_catalog.field'|trans }}</th>
                                <th>{{ 'admin_catalog.reason'|trans }}</th>
                                <th>{{ 'admin_catalog.value_a'|trans }}</th>
                                <th>{{ 'admin_catalog.value_b'|trans }}</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for conflict in selectedItem.sourceMerge.conflicts %}
                                <tr>
                                    <td><code>{{ conflict.field }}</code></td>
                                    <td><code>{{ conflict.reason }}</code></td>
                                    <td><pre class="admin-catalog-code-block">{{ conflict.value_a|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre></td>
                                    <td><pre class="admin-catalog-code-block">{{ conflict.value_b|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre></td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td class="admin-empty-cell" colspan="4">{{ 'admin_catalog.no_merge_conflicts'|trans }}</td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <p class="catalog-state">{{ 'admin_catalog.no_source_merge'|trans }}</p>
                {% endif %}
            {% else %}
                <p class="catalog-state">{{ 'admin_catalog.no_selected_item'|trans }}</p>
            {% endif %}
        </section>
    </main>
{% endblock %}
