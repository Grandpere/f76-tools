{% extends 'base.html.twig' %}

{% block title %}{{ 'admin_translations.page_title'|trans }}{% endblock %}

{% block body %}
    <main class="translations-page">
        <header class="translations-header">
            <div class="catalog-header-tools">
                <a class="header-translations-link" href="{{ path('app_dashboard', { locale: app.request.locale }) }}">{{ 'admin_translations.back_to_dashboard'|trans }}</a>
                <form class="header-locale" method="get">
                    <input type="hidden" name="target" value="{{ targetLocale }}">
                    {% if query %}
                        <input type="hidden" name="q" value="{{ query }}">
                    {% endif %}
                    <input type="hidden" name="perPage" value="{{ perPage }}">
                    <input type="hidden" name="page" value="{{ page }}">
                    <img class="header-locale-icon" src="/assets/icons/language.svg" alt="" aria-hidden="true">
                    <label for="admin-header-locale-select">{{ 'common.language'|trans }}</label>
                    <select id="admin-header-locale-select" name="locale" onchange="this.form.submit()">
                        <option value="fr" {% if app.request.locale == 'fr' %}selected{% endif %}>🇫🇷 {{ 'common.locale.fr'|trans }}</option>
                        <option value="en" {% if app.request.locale == 'en' %}selected{% endif %}>🇬🇧 {{ 'common.locale.en'|trans }}</option>
                        <option value="de" {% if app.request.locale == 'de' %}selected{% endif %}>🇩🇪 {{ 'common.locale.de'|trans }}</option>
                    </select>
                </form>
            </div>
            <p class="catalog-kicker">{{ 'admin_translations.kicker'|trans }}</p>
            <h1>{{ 'admin_translations.title'|trans }}</h1>
            <p>{{ 'admin_translations.editing_catalog'|trans({'%locale%': targetLocale}) }}</p>
            {% include 'admin/_nav_links.html.twig' %}
        </header>

        {% for message in app.flashes('success') %}
            <p class="translations-flash success">{{ message }}</p>
        {% endfor %}
        {% for message in app.flashes('warning') %}
            <p class="translations-flash warning">{{ message }}</p>
        {% endfor %}

        <section class="translations-panel">
            <form method="get" class="translations-filters">
                <label class="field">
                    <span>{{ 'admin_translations.target_file'|trans }}</span>
                    <input type="text" name="target" value="{{ targetLocale }}" placeholder="fr">
                </label>
                <label class="field">
                    <span>{{ 'admin_translations.search'|trans }}</span>
                    <input type="search" name="q" value="{{ query }}" placeholder="{{ 'admin_translations.search_placeholder'|trans }}">
                </label>
                <label class="field">
                    <span>{{ 'admin_translations.per_page'|trans }}</span>
                    <select name="perPage">
                        <option value="20" {% if perPage == 20 %}selected{% endif %}>20</option>
                        <option value="40" {% if perPage == 40 %}selected{% endif %}>40</option>
                        <option value="80" {% if perPage == 80 %}selected{% endif %}>80</option>
                        <option value="120" {% if perPage == 120 %}selected{% endif %}>120</option>
                    </select>
                </label>
                <input type="hidden" name="locale" value="{{ app.request.locale }}">
                <input type="hidden" name="page" value="1">
                <button type="submit">{{ 'admin_translations.filter'|trans }}</button>
            </form>
            <p class="catalog-state">{{ 'admin_translations.visible_rows'|trans({'%count%': totalRows}) }}</p>
            {% if totalPages > 1 %}
                <div class="translations-pager">
                    {% if page > 1 %}
                        <a href="{{ path('app_admin_item_translations', { locale: app.request.locale, target: targetLocale, q: query ?: null, perPage: perPage, page: page - 1 }) }}">{{ 'admin_translations.pagination_prev'|trans }}</a>
                    {% endif %}
                    <span>{{ 'admin_translations.pagination_page'|trans({'%page%': page, '%total%': totalPages}) }}</span>
                    {% if page < totalPages %}
                        <a href="{{ path('app_admin_item_translations', { locale: app.request.locale, target: targetLocale, q: query ?: null, perPage: perPage, page: page + 1 }) }}">{{ 'admin_translations.pagination_next'|trans }}</a>
                    {% endif %}
                </div>
            {% endif %}

            <form method="post" data-controller="textarea-autosize">
                <input type="hidden" name="_token" value="{{ csrf_token('admin_item_translations_save') }}">
                <input type="hidden" name="target" value="{{ targetLocale }}">
                <input type="hidden" name="perPage" value="{{ perPage }}">
                <input type="hidden" name="page" value="{{ page }}">
                <div class="translations-table-wrap">
                    <table class="translations-table">
                        <caption class="visually-hidden">{{ 'admin_translations.table_caption'|trans({'%locale%': targetLocale}) }}</caption>
                        <thead>
                        <tr>
                            <th>{{ 'admin_translations.key'|trans }}</th>
                            <th>{{ targetLocale|upper }}</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% set currentSection = '' %}
                        {% for row in rows %}
                            {% if currentSection != row.section %}
                                {% set currentSection = row.section %}
                                <tr class="translations-section-row">
                                    <td colspan="2">
                                        {% if row.section == 'misc' %}# misc (legendary mod){% else %}# book (minerva plan){% endif %}
                                    </td>
                                </tr>
                            {% endif %}
                            <tr>
                                <td><code>{{ row.key }}</code></td>
                                <td>
                                    <textarea name="entries[{{ row.key }}]" rows="4" data-autosize="true">{{ row.target }}</textarea>
                                    <p class="translations-help"><strong>EN:</strong> {{ row.en }}</p>
                                    <p class="translations-help"><strong>DE:</strong> {{ row.de }}</p>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="2">{{ 'admin_translations.no_entries'|trans }}</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
                <div class="translations-actions">
                    <span class="catalog-state">{{ 'admin_translations.visible_page_rows'|trans({'%count%': pageRows}) }}</span>
                    <button type="submit">{{ 'admin_translations.save'|trans }}</button>
                </div>
            </form>
        </section>
    </main>
{% endblock %}
