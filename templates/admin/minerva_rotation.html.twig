{% extends 'base.html.twig' %}

{% block title %}{{ 'admin_minerva.page_title'|trans }}{% endblock %}

{% block body %}
    <main class="translations-page">
        {% include 'admin/_page_header.html.twig' with {
            backLabel: 'admin_minerva.back_to_dashboard',
            localeSelectId: 'admin-minerva-header-locale-select',
            kicker: 'admin_minerva.kicker',
            title: 'admin_minerva.title',
            description: 'admin_minerva.description'|trans
        } %}

        {% include 'admin/_flashes.html.twig' %}

        <section class="translations-panel">
            <h2>{{ 'admin_minerva.regenerate_title'|trans }}</h2>
            <div class="admin-minerva-governance" data-minerva-governance="1">
                <p class="admin-minerva-governance-title">{{ 'admin_minerva.governance_title'|trans }}</p>
                <ul>
                    <li>{{ 'admin_minerva.governance_primary'|trans }}</li>
                    <li>{{ 'admin_minerva.governance_override'|trans }}</li>
                    <li>{{ 'admin_minerva.governance_recovery'|trans }}</li>
                </ul>
            </div>
            <form method="post" action="{{ path('app_admin_minerva_rotation_regenerate', { locale: app.request.locale }) }}" class="translations-filters minerva-admin-filters" data-controller="minerva-admin-datepicker" data-minerva-admin-datepicker-locale-value="{{ app.request.locale }}">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_minerva_rotation_regenerate') }}">
                <label class="field">
                    <span>{{ 'admin_minerva.from'|trans }}</span>
                    <input type="date" name="from" value="{{ defaultFrom }}">
                </label>
                <label class="field">
                    <span>{{ 'admin_minerva.to'|trans }}</span>
                    <input type="date" name="to" value="{{ defaultTo }}">
                </label>
                <button type="submit">{{ 'admin_minerva.regenerate'|trans }}</button>
            </form>
            <form method="post" action="{{ path('app_admin_minerva_rotation_refresh', { locale: app.request.locale }) }}" class="translations-filters minerva-admin-filters" data-controller="minerva-admin-datepicker" data-minerva-admin-datepicker-locale-value="{{ app.request.locale }}">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_minerva_rotation_refresh') }}">
                <label class="field">
                    <span>{{ 'admin_minerva.from'|trans }}</span>
                    <input type="date" name="from" value="{{ defaultFrom }}">
                </label>
                <label class="field">
                    <span>{{ 'admin_minerva.to'|trans }}</span>
                    <input type="date" name="to" value="{{ defaultTo }}">
                </label>
                <label class="field">
                    <span>{{ 'admin_minerva.refresh_dry_run'|trans }}</span>
                    <input type="checkbox" name="dryRun" value="1">
                </label>
                <button type="submit">{{ 'admin_minerva.refresh'|trans }}</button>
            </form>
            <p class="catalog-state">{{ 'admin_minerva.timezone'|trans({'%timezone%': timeline.timezone}) }}</p>
            <div
                class="admin-minerva-freshness {{ freshness.missingWindows|default(0) > 0 ? 'admin-minerva-freshness-stale' : '' }}"
                data-minerva-freshness="1"
                data-minerva-expected-windows="{{ freshness.expectedWindows|default(0) }}"
                data-minerva-missing-windows="{{ freshness.missingWindows|default(0) }}"
                data-minerva-covered="{{ freshness.covered|default(false) ? '1' : '0' }}"
                data-minerva-stale="{{ freshness.missingWindows|default(0) > 0 ? '1' : '0' }}"
            >
                <div class="admin-minerva-freshness-header">
                    <h3>{{ 'admin_minerva.freshness_title'|trans }}</h3>
                    <span class="item-pill {{ freshness.covered|default(false) ? 'admin-minerva-freshness-pill-ok' : 'admin-minerva-freshness-pill-warn' }}">
                        {{ freshness.covered|default(false) ? 'admin_minerva.freshness_status_covered'|trans : 'admin_minerva.freshness_status_missing'|trans }}
                    </span>
                </div>
                <p
                    class="admin-minerva-consistency-line"
                    data-minerva-consistency-status="{{ freshness.covered|default(false) ? 'ok' : 'drift' }}"
                >
                    {{ freshness.covered|default(false) ? 'admin_minerva.consistency_ok'|trans : 'admin_minerva.consistency_drift'|trans }}
                </p>
                <dl class="admin-minerva-freshness-grid">
                    <div>
                        <dt>{{ 'admin_minerva.freshness_range_label'|trans }}</dt>
                        <dd>{{ defaultFrom }} &rarr; {{ defaultTo }}</dd>
                    </div>
                    <div>
                        <dt>{{ 'admin_minerva.freshness_expected_label'|trans }}</dt>
                        <dd>{{ freshness.expectedWindows|default(0) }}</dd>
                    </div>
                    <div>
                        <dt>{{ 'admin_minerva.freshness_missing_label'|trans }}</dt>
                        <dd>{{ freshness.missingWindows|default(0) }}</dd>
                    </div>
                    <div>
                        <dt>{{ 'admin_minerva.freshness_last_generated_label'|trans }}</dt>
                        <dd>{{ latestGeneratedAt ? latestGeneratedAt|date('Y-m-d H:i') : ('admin_minerva.freshness_never'|trans) }}</dd>
                    </div>
                    <div>
                        <dt>{{ 'admin_minerva.freshness_last_manual_label'|trans }}</dt>
                        <dd>{{ latestManualAt ? latestManualAt|date('Y-m-d H:i') : ('admin_minerva.freshness_never'|trans) }}</dd>
                    </div>
                </dl>
                {% if freshness.missingWindows|default(0) > 0 %}
                    <p class="admin-minerva-freshness-alert">{{ 'admin_minerva.freshness_alert_missing'|trans }}</p>
                {% endif %}
                {% if latestRefreshSummary %}
                    <div
                        class="admin-minerva-last-refresh"
                        data-minerva-last-refresh="1"
                        data-minerva-last-refresh-action="{{ latestRefreshSummary.action }}"
                        data-minerva-last-refresh-expected="{{ latestRefreshSummary.expectedWindows }}"
                        data-minerva-last-refresh-missing="{{ latestRefreshSummary.missingWindows }}"
                        data-minerva-last-refresh-deleted="{{ latestRefreshSummary.deleted }}"
                        data-minerva-last-refresh-inserted="{{ latestRefreshSummary.inserted }}"
                        data-minerva-last-refresh-skipped="{{ latestRefreshSummary.skipped }}"
                        data-minerva-last-refresh-dry-run="{{ latestRefreshSummary.dryRun ? '1' : '0' }}"
                    >
                        <p class="admin-minerva-last-refresh-title">{{ 'admin_minerva.last_refresh_title'|trans }}</p>
                        <p class="admin-minerva-last-refresh-line">
                            {{ 'admin_minerva.last_refresh_meta'|trans({
                                '%date%': latestRefreshSummary.occurredAt|date('Y-m-d H:i'),
                                '%actor%': latestRefreshSummary.actorEmail
                            }) }}
                        </p>
                        <p class="admin-minerva-last-refresh-line">
                            {{ ('admin_minerva.last_refresh_action_' ~ latestRefreshSummary.action)|trans }}
                        </p>
                        <p class="admin-minerva-last-refresh-line">
                            {{ 'admin_minerva.last_refresh_summary'|trans({
                                '%expected%': latestRefreshSummary.expectedWindows,
                                '%missing%': latestRefreshSummary.missingWindows,
                                '%deleted%': latestRefreshSummary.deleted,
                                '%inserted%': latestRefreshSummary.inserted,
                                '%skipped%': latestRefreshSummary.skipped
                            }) }}
                        </p>
                    </div>
                {% endif %}
                <p class="admin-minerva-last-refresh-line admin-minerva-audit-link-row">
                    <a href="{{ path('app_admin_audit_logs', { locale: app.request.locale, q: 'minerva_', perPage: 30, page: 1 }) }}">{{ 'admin_minerva.view_minerva_audit_logs'|trans }}</a>
                </p>
            </div>
        </section>

        <section class="translations-panel">
            <h2>{{ 'admin_minerva.override_title'|trans }}</h2>
            <form method="post" action="{{ path('app_admin_minerva_rotation_override_create', { locale: app.request.locale }) }}" class="translations-filters minerva-admin-filters" data-controller="minerva-admin-datepicker" data-minerva-admin-datepicker-locale-value="{{ app.request.locale }}">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_minerva_rotation_override_create') }}">
                <input type="hidden" name="from" value="{{ defaultFrom }}">
                <input type="hidden" name="to" value="{{ defaultTo }}">
                <label class="field">
                    <span>{{ 'admin_minerva.override_location'|trans }}</span>
                    <input type="text" name="location" required maxlength="120" placeholder="Foundation">
                </label>
                <label class="field">
                    <span>{{ 'admin_minerva.override_list'|trans }}</span>
                    <input type="number" min="1" max="24" name="listCycle" required>
                </label>
                <label class="field">
                    <span>{{ 'admin_minerva.override_starts_at'|trans }}</span>
                    <input type="datetime-local" name="startsAt" required>
                </label>
                <label class="field">
                    <span>{{ 'admin_minerva.override_ends_at'|trans }}</span>
                    <input type="datetime-local" name="endsAt" required>
                </label>
                <button type="submit">{{ 'admin_minerva.override_create'|trans }}</button>
            </form>
            <div class="translations-table-wrap">
                <table class="translations-table">
                    <thead>
                    <tr>
                        <th>{{ 'minerva.location'|trans }}</th>
                        <th>{{ 'minerva.list_cycle'|trans }}</th>
                        <th>{{ 'minerva.starts_at'|trans }}</th>
                        <th>{{ 'minerva.ends_at'|trans }}</th>
                        <th>{{ 'admin_minerva.override_actions'|trans }}</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for row in manualOverrides %}
                        <tr>
                            <td>{{ row.location }}</td>
                            <td>{{ row.listCycle }}</td>
                            <td>{{ row.startsAt|date('D d M Y · H:i') }}</td>
                            <td>{{ row.endsAt|date('D d M Y · H:i') }}</td>
                            <td>
                                <form method="post" action="{{ path('app_admin_minerva_rotation_override_delete', { locale: app.request.locale, id: row.id }) }}">
                                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_minerva_rotation_override_delete_' ~ row.id) }}">
                                    <input type="hidden" name="from" value="{{ defaultFrom }}">
                                    <input type="hidden" name="to" value="{{ defaultTo }}">
                                    <button type="submit">{{ 'admin_minerva.override_delete'|trans }}</button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5">{{ 'admin_minerva.override_empty'|trans }}</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>

        <section class="translations-panel">
            <h2>{{ 'admin_minerva.timeline_title'|trans }}</h2>
            <div class="translations-table-wrap">
                <table class="translations-table admin-minerva-timeline-table">
                    <colgroup>
                        <col class="col-list">
                        <col class="col-location">
                        <col class="col-start">
                        <col class="col-end">
                        <col class="col-source">
                        <col class="col-status">
                    </colgroup>
                    <thead>
                    <tr>
                        <th>{{ 'minerva.list_cycle'|trans }}</th>
                        <th>{{ 'minerva.location'|trans }}</th>
                        <th>{{ 'minerva.starts_at'|trans }}</th>
                        <th>{{ 'minerva.ends_at'|trans }}</th>
                        <th>{{ 'admin_minerva.source'|trans }}</th>
                        <th>{{ 'minerva.status'|trans }}</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for row in timeline.rows %}
                        <tr>
                            <td>{{ row.listCycle }}</td>
                            <td>{{ row.location }}</td>
                            <td>{{ row.startsAt|date('D d M Y · H:i') }}</td>
                            <td>{{ row.endsAt|date('D d M Y · H:i') }}</td>
                            <td><span class="item-pill">{{ ('admin_minerva.source_' ~ row.source)|trans }}</span></td>
                            <td><span class="item-pill">{{ ('minerva.status_' ~ row.status)|trans }}</span></td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6">{{ 'minerva.empty'|trans }}</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>
    </main>
{% endblock %}
