{% extends 'base.html.twig' %}

{% block title %}{{ 'admin_minerva.page_title'|trans }}{% endblock %}

{% block body %}
    <main class="translations-page">
        <header class="translations-header">
            <div class="catalog-header-tools">
                <a class="header-translations-link" href="{{ path('app_dashboard', { locale: app.request.locale }) }}">{{ 'admin_minerva.back_to_dashboard'|trans }}</a>
                <form class="header-locale" method="get">
                    <img class="header-locale-icon" src="/assets/icons/language.svg" alt="" aria-hidden="true">
                    <label for="admin-minerva-header-locale-select">{{ 'common.language'|trans }}</label>
                    <select id="admin-minerva-header-locale-select" name="locale" onchange="this.form.submit()">
                        <option value="fr" {% if app.request.locale == 'fr' %}selected{% endif %}>🇫🇷 {{ 'common.locale.fr'|trans }}</option>
                        <option value="en" {% if app.request.locale == 'en' %}selected{% endif %}>🇬🇧 {{ 'common.locale.en'|trans }}</option>
                        <option value="de" {% if app.request.locale == 'de' %}selected{% endif %}>🇩🇪 {{ 'common.locale.de'|trans }}</option>
                    </select>
                </form>
            </div>
            <p class="catalog-kicker">{{ 'admin_minerva.kicker'|trans }}</p>
            <h1>{{ 'admin_minerva.title'|trans }}</h1>
            <p>{{ 'admin_minerva.description'|trans }}</p>
            {% include 'admin/_nav_links.html.twig' %}
        </header>

        {% for message in app.flashes('success') %}
            <p class="translations-flash success">{{ message|trans }}</p>
        {% endfor %}
        {% for message in app.flashes('warning') %}
            <p class="translations-flash warning">{{ message|trans }}</p>
        {% endfor %}

        <section class="translations-panel">
            <h2>{{ 'admin_minerva.regenerate_title'|trans }}</h2>
            <form method="post" action="{{ path('app_admin_minerva_rotation_regenerate', { locale: app.request.locale }) }}" class="translations-filters">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_minerva_rotation_regenerate') }}">
                <label class="field">
                    <span>{{ 'admin_minerva.from'|trans }}</span>
                    <input type="date" name="from" value="{{ defaultFrom }}">
                </label>
                <label class="field">
                    <span>{{ 'admin_minerva.to'|trans }}</span>
                    <input type="date" name="to" value="{{ defaultTo }}">
                </label>
                <button type="submit">{{ 'admin_minerva.regenerate'|trans }}</button>
            </form>
            <p class="catalog-state">{{ 'admin_minerva.timezone'|trans({'%timezone%': timeline.timezone}) }}</p>
        </section>

        <section class="translations-panel">
            <h2>{{ 'admin_minerva.timeline_title'|trans }}</h2>
            <div class="translations-table-wrap">
                <table class="translations-table">
                    <thead>
                    <tr>
                        <th>{{ 'minerva.status'|trans }}</th>
                        <th>{{ 'minerva.location'|trans }}</th>
                        <th>{{ 'minerva.list_cycle'|trans }}</th>
                        <th>{{ 'minerva.starts_at'|trans }}</th>
                        <th>{{ 'minerva.ends_at'|trans }}</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for row in timeline.rows %}
                        <tr>
                            <td><span class="item-pill">{{ ('minerva.status_' ~ row.status)|trans }}</span></td>
                            <td>{{ row.location }}</td>
                            <td>{{ row.listCycle }}</td>
                            <td>{{ row.startsAt|date('Y-m-d H:i') }}</td>
                            <td>{{ row.endsAt|date('Y-m-d H:i') }}</td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5">{{ 'minerva.empty'|trans }}</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>
    </main>
{% endblock %}
