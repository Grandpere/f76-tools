{% extends 'base.html.twig' %}

{% block title %}{{ 'security.register.page_title'|trans }}{% endblock %}

{% block body %}
    <main class="auth-page">
        <section class="auth-card">
            <p class="catalog-kicker">Fallout 76</p>
            <h1 class="auth-title">{{ 'security.register.title'|trans }}</h1>

            {% for message in app.flashes('success') %}
                <p class="auth-alert auth-alert-success">{{ message|trans }}</p>
            {% endfor %}
            {% for message in app.flashes('warning') %}
                <p class="auth-alert auth-alert-warning">{{ message|trans }}</p>
            {% endfor %}

            <form method="post" class="auth-form">
                <div class="visually-hidden" aria-hidden="true">
                    <label for="register-website">Website</label>
                    <input id="register-website" name="website" type="text" tabindex="-1" autocomplete="off">
                </div>
                <label class="auth-field" for="register-email">
                    <span>{{ 'security.register.email'|trans }}</span>
                    <input
                        id="register-email"
                        name="email"
                        type="email"
                        required
                        autocomplete="email"
                    >
                </label>

                <label class="auth-field" for="register-password">
                    <span>{{ 'security.register.password'|trans }}</span>
                    <input
                        id="register-password"
                        name="password"
                        type="password"
                        required
                        autocomplete="new-password"
                    >
                </label>

                <label class="auth-field" for="register-password-confirm">
                    <span>{{ 'security.register.password_confirm'|trans }}</span>
                    <input
                        id="register-password-confirm"
                        name="password_confirm"
                        type="password"
                        required
                        autocomplete="new-password"
                    >
                </label>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('register') }}">
                {% if captchaSiteKey %}
                    <div class="cf-turnstile" data-sitekey="{{ captchaSiteKey }}"></div>
                {% endif %}

                <button type="submit">{{ 'security.register.submit'|trans }}</button>
            </form>

            <p class="auth-links">
                <a href="{{ path('app_login', { locale: app.request.locale }) }}">{{ 'security.register.to_login'|trans }}</a>
                <a href="{{ path('app_forgot_password', { locale: app.request.locale }) }}">{{ 'security.login.to_forgot'|trans }}</a>
                <a href="{{ path('app_contact', { locale: app.request.locale }) }}">{{ 'security.login.to_contact'|trans }}</a>
            </p>
        </section>
    </main>
    {% if captchaSiteKey %}
        <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
    {% endif %}
{% endblock %}
