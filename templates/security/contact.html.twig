{% extends 'base.html.twig' %}

{% block title %}{{ 'security.contact.page_title'|trans }}{% endblock %}

{% block body %}
    <main class="auth-page">
        <section class="auth-card">
            {% include 'security/_card_header.html.twig' with { title: 'security.contact.title' } %}

            {% include 'security/_flashes.html.twig' %}

            <form method="post" class="auth-form">
                {% include 'security/_honeypot_field.html.twig' with { honeypotId: 'contact-website' } %}
                <label class="auth-field" for="contact-email">
                    <span>{{ 'security.contact.email'|trans }}</span>
                    <input id="contact-email" name="email" type="email" required autocomplete="email">
                </label>
                <label class="auth-field" for="contact-subject">
                    <span>{{ 'security.contact.subject'|trans }}</span>
                    <input id="contact-subject" name="subject" type="text" required minlength="3">
                </label>
                <label class="auth-field" for="contact-message">
                    <span>{{ 'security.contact.message'|trans }}</span>
                    <textarea id="contact-message" name="message" rows="6" required minlength="10"></textarea>
                </label>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('contact') }}">
                {% include 'security/_turnstile.html.twig' %}

                <div class="auth-primary-actions">
                    <button type="submit">{{ 'security.contact.submit'|trans }}</button>
                    <a class="auth-button-link" href="{{ path('app_register', { locale: app.request.locale }) }}">{{ 'security.login.to_register'|trans }}</a>
                </div>
            </form>

            {% include 'security/_links.html.twig' with {
                links: [
                    { route: 'app_login', label: 'security.contact.to_login' }
                ]
            } %}
        </section>
    </main>
    {% include 'security/_turnstile_script.html.twig' %}
{% endblock %}
