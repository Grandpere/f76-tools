{% extends 'base.html.twig' %}

{% block title %}{{ 'security.login.page_title'|trans }}{% endblock %}

{% block body %}
    <main class="auth-page">
        <section class="auth-card">
            <p class="catalog-kicker">Fallout 76</p>
            <h1 class="auth-title">{{ 'security.login.title'|trans }}</h1>

            {% if error %}
                <p class="auth-alert auth-alert-warning">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </p>
            {% endif %}
            {% for message in app.flashes('success') %}
                <p class="auth-alert auth-alert-success">{{ message|trans }}</p>
            {% endfor %}
            {% for message in app.flashes('warning') %}
                <p class="auth-alert auth-alert-warning">{{ message|trans }}</p>
            {% endfor %}

            <form method="post" class="auth-form">
                <label class="auth-field" for="username">
                    <span>{{ 'security.login.email'|trans }}</span>
                    <input
                        id="username"
                        name="_username"
                        type="email"
                        value="{{ last_username }}"
                        required
                        autofocus
                        autocomplete="username"
                    >
                </label>

                <label class="auth-field" for="password">
                    <span>{{ 'security.login.password'|trans }}</span>
                    <input
                        id="password"
                        name="_password"
                        type="password"
                        required
                        autocomplete="current-password"
                    >
                </label>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <div class="auth-primary-actions">
                    <button type="submit">{{ 'security.login.submit'|trans }}</button>
                    <a class="auth-button-link" href="{{ path('app_register', { locale: app.request.locale }) }}">{{ 'security.login.to_register'|trans }}</a>
                </div>
            </form>

            <p class="auth-links">
                <a href="{{ path('app_resend_verification', { locale: app.request.locale }) }}">{{ 'security.login.to_resend'|trans }}</a>
                <a href="{{ path('app_forgot_password', { locale: app.request.locale }) }}">{{ 'security.login.to_forgot'|trans }}</a>
                <a href="{{ path('app_contact', { locale: app.request.locale }) }}">{{ 'security.login.to_contact'|trans }}</a>
            </p>
        </section>
    </main>
{% endblock %}
