{% extends 'base.html.twig' %}

{% block title %}{{ 'security.reset.page_title'|trans }}{% endblock %}

{% block body %}
    <main class="auth-page">
        <section class="auth-card">
            <p class="catalog-kicker">Fallout 76</p>
            <h1 class="auth-title">{{ 'security.reset.title'|trans }}</h1>

            {% for message in app.flashes('success') %}
                <p class="auth-alert auth-alert-success">{{ message|trans }}</p>
            {% endfor %}
            {% for message in app.flashes('warning') %}
                <p class="auth-alert auth-alert-warning">{{ message|trans }}</p>
            {% endfor %}

            <form method="post" class="auth-form">
                <label class="auth-field" for="reset-password">
                    <span>{{ 'security.reset.password'|trans }}</span>
                    <input
                        id="reset-password"
                        name="password"
                        type="password"
                        required
                        autocomplete="new-password"
                    >
                </label>

                <label class="auth-field" for="reset-password-confirm">
                    <span>{{ 'security.reset.password_confirm'|trans }}</span>
                    <input
                        id="reset-password-confirm"
                        name="password_confirm"
                        type="password"
                        required
                        autocomplete="new-password"
                    >
                </label>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('reset_password') }}">

                <button type="submit">{{ 'security.reset.submit'|trans }}</button>
            </form>
        </section>
    </main>
{% endblock %}
