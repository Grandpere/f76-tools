{% extends 'base.html.twig' %}

{% block title %}{{ 'security.reset.page_title'|trans }}{% endblock %}

{% block body %}
    <main class="auth-page">
        <section class="auth-card">
            {% include 'security/_card_header.html.twig' with { title: 'security.reset.title' } %}

            {% include 'security/_flashes.html.twig' %}

            <form method="post" class="auth-form">
                <label class="auth-field" for="reset-password">
                    <span>{{ 'security.reset.password'|trans }}</span>
                    <input
                        id="reset-password"
                        name="password"
                        type="password"
                        required
                        autocomplete="new-password"
                    >
                </label>

                <label class="auth-field" for="reset-password-confirm">
                    <span>{{ 'security.reset.password_confirm'|trans }}</span>
                    <input
                        id="reset-password-confirm"
                        name="password_confirm"
                        type="password"
                        required
                        autocomplete="new-password"
                    >
                </label>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('reset_password') }}">

                <div class="auth-primary-actions">
                    <button type="submit">{{ 'security.reset.submit'|trans }}</button>
                    <a class="auth-button-link" href="{{ path('app_register', { locale: app.request.locale }) }}">{{ 'security.login.to_register'|trans }}</a>
                </div>
            </form>

            {% include 'security/_links.html.twig' with {
                links: [
                    { route: 'app_login', label: 'security.reset.to_login' },
                    { route: 'app_forgot_password', label: 'security.login.to_forgot' },
                    { route: 'app_contact', label: 'security.login.to_contact' }
                ]
            } %}
        </section>
    </main>
{% endblock %}
