{% extends 'base.html.twig' %}

{% block title %}{{ 'security.reset.page_title'|trans }}{% endblock %}

{% block body %}
    <main style="max-width: 420px; margin: 3rem auto; font-family: system-ui, sans-serif;">
        <h1>{{ 'security.reset.title'|trans }}</h1>

        {% for message in app.flashes('success') %}
            <p style="color: #166534; margin-bottom: 1rem;">{{ message|trans }}</p>
        {% endfor %}
        {% for message in app.flashes('warning') %}
            <p style="color: #b91c1c; margin-bottom: 1rem;">{{ message|trans }}</p>
        {% endfor %}

        <form method="post">
            <label for="reset-password">{{ 'security.reset.password'|trans }}</label>
            <input
                id="reset-password"
                name="password"
                type="password"
                required
                autocomplete="new-password"
                style="display:block; width:100%; margin:0.25rem 0 1rem; padding:0.5rem;"
            >

            <label for="reset-password-confirm">{{ 'security.reset.password_confirm'|trans }}</label>
            <input
                id="reset-password-confirm"
                name="password_confirm"
                type="password"
                required
                autocomplete="new-password"
                style="display:block; width:100%; margin:0.25rem 0 1rem; padding:0.5rem;"
            >

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('reset_password') }}">

            <button
                type="submit"
                style="padding: 0.6rem 1rem; border: 0; background: #111827; color: #fff; cursor: pointer;"
            >
                {{ 'security.reset.submit'|trans }}
            </button>
        </form>
    </main>
{% endblock %}
