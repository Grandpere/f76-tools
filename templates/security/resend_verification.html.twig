{% extends 'base.html.twig' %}

{% block title %}{{ 'security.resend.page_title'|trans }}{% endblock %}

{% block body %}
    <main class="auth-page">
        <section class="auth-card">
            <p class="catalog-kicker">Fallout 76</p>
            <h1 class="auth-title">{{ 'security.resend.title'|trans }}</h1>

            {% include 'security/_flashes.html.twig' %}

            <form method="post" class="auth-form">
                {% include 'security/_honeypot_field.html.twig' with { honeypotId: 'resend-website' } %}
                <label class="auth-field" for="resend-email">
                    <span>{{ 'security.resend.email'|trans }}</span>
                    <input
                        id="resend-email"
                        name="email"
                        type="email"
                        required
                        autocomplete="email"
                    >
                </label>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('resend_verification') }}">
                {% include 'security/_turnstile.html.twig' %}

                <div class="auth-primary-actions">
                    <button type="submit">{{ 'security.resend.submit'|trans }}</button>
                    <a class="auth-button-link" href="{{ path('app_register', { locale: app.request.locale }) }}">{{ 'security.login.to_register'|trans }}</a>
                </div>
            </form>

            <p class="auth-links">
                <a href="{{ path('app_login', { locale: app.request.locale }) }}">{{ 'security.resend.to_login'|trans }}</a>
                <a href="{{ path('app_contact', { locale: app.request.locale }) }}">{{ 'security.login.to_contact'|trans }}</a>
            </p>
        </section>
    </main>
    {% include 'security/_turnstile_script.html.twig' %}
{% endblock %}
