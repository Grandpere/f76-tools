{% extends 'base.html.twig' %}

{% block title %}{{ 'security.account.page_title'|trans }}{% endblock %}

{% block body %}
    <main class="auth-page">
        <section class="auth-card">
            {% include 'security/_card_header.html.twig' with { title: 'security.account.title' } %}
            {% include 'security/_flashes.html.twig' %}

            <dl class="account-security-list">
                <div class="account-security-row">
                    <dt>{{ 'security.account.email'|trans }}</dt>
                    <dd>{{ userEmail }}</dd>
                </div>
                <div class="account-security-row">
                    <dt>{{ 'security.account.email_verified'|trans }}</dt>
                    <dd>
                        {% if emailVerified %}
                            <span class="admin-security-badge admin-security-badge-ok">{{ 'common.yes'|trans }}</span>
                        {% else %}
                            <span class="admin-security-badge admin-security-badge-warn">{{ 'common.no'|trans }}</span>
                        {% endif %}
                    </dd>
                </div>
                <div class="account-security-row">
                    <dt>{{ 'security.account.local_password'|trans }}</dt>
                    <dd>
                        {% if localPasswordEnabled %}
                            <span class="admin-security-badge admin-security-badge-ok">{{ 'common.yes'|trans }}</span>
                        {% else %}
                            <span class="admin-security-badge admin-security-badge-warn">{{ 'common.no'|trans }}</span>
                        {% endif %}
                    </dd>
                </div>
                <div class="account-security-row">
                    <dt>{{ 'security.account.google_linked'|trans }}</dt>
                    <dd>
                        {% if googleLinked %}
                            <span class="admin-security-badge admin-security-badge-ok">{{ 'common.yes'|trans }}</span>
                            {% if googleLinkedAt %}
                                <small class="account-security-sub">{{ 'security.account.google_linked_since'|trans({'%date%': googleLinkedAt|date('Y-m-d H:i')}) }}</small>
                            {% endif %}
                        {% else %}
                            <span class="admin-security-badge admin-security-badge-warn">{{ 'common.no'|trans }}</span>
                        {% endif %}
                    </dd>
                </div>
            </dl>

            <section class="account-security-sessions">
                <div class="account-security-section-head">
                    <h3>{{ 'security.account.sessions_title'|trans }}</h3>
                    <span class="account-security-counter">{{ 'security.account.sessions_count'|trans({'%count%': activeSessionsCount}) }}</span>
                </div>
                <p class="account-security-sub">{{ 'security.account.sessions_hint'|trans }}</p>
                <ul class="account-security-session-list">
                    {% for session in activeSessions %}
                        {% set isCurrentSession = currentSessionId is same as(session.sessionId) %}
                        <li class="account-security-session-item">
                            <div>
                                <strong>{{ isCurrentSession ? 'security.account.session_current'|trans : 'security.account.session_other'|trans }}</strong>
                                <small>
                                    {{ 'security.account.session_last_seen'|trans({'%date%': session.lastSeenAt|date('Y-m-d H:i')}) }}
                                    {% if session.ipAddress %}· {{ session.ipAddress }}{% endif %}
                                </small>
                            </div>
                            {% if session.userAgent %}
                                <small>{{ session.userAgent }}</small>
                            {% endif %}
                        </li>
                    {% else %}
                        <li class="account-security-session-item">{{ 'security.account.session_none'|trans }}</li>
                    {% endfor %}
                </ul>
                {% if activeSessions|length > 1 %}
                    <form method="post" action="{{ path('app_account_security_logout_other_sessions', { _locale: app.request.locale }) }}" class="account-security-unlink-form">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('account_logout_other_sessions') }}">
                        <button class="auth-button-link auth-button-link-secondary" type="submit">{{ 'security.account.logout_other_sessions'|trans }}</button>
                    </form>
                {% endif %}
            </section>

            <section class="account-security-sessions">
                <div class="account-security-section-head">
                    <h3>{{ 'security.account.auth_events_title'|trans }}</h3>
                    <div class="account-security-section-actions">
                        <span class="account-security-counter">{{ 'security.account.auth_events_count'|trans({'%count%': authEventsCount}) }}</span>
                        {% if isAdmin %}
                            <a class="account-security-admin-link" href="{{ path('app_admin_users_auth_events', { _locale: app.request.locale, id: userId }) }}">{{ 'security.account.auth_events_admin_link'|trans }}</a>
                        {% endif %}
                    </div>
                </div>
                <p class="account-security-sub">{{ 'security.account.auth_events_hint'|trans }}</p>
                <ul class="account-security-session-list">
                    {% for event in authEvents %}
                        {% set rawEventLabel = event.event %}
                        {% set translatedEventLabel = rawEventLabel|trans %}
                        {% set displayEventLabel = translatedEventLabel != rawEventLabel
                            ? translatedEventLabel
                            : rawEventLabel
                                |replace({'security.auth.': '', 'security.account.': '', 'security.': '', '.': ' '})
                                |title
                        %}
                        <li class="account-security-session-item">
                            <strong>
                                {{ displayEventLabel }}
                                <span class="admin-security-badge {{ event.level == 'warning' ? 'admin-security-badge-warn' : 'admin-security-badge-ok' }}">{{ event.level }}</span>
                            </strong>
                            <small>{{ event.occurredAt|date('Y-m-d H:i:s') }}{% if event.clientIp %} · {{ event.clientIp }}{% endif %}</small>
                        </li>
                    {% else %}
                        <li class="account-security-session-item">{{ 'security.account.auth_events_empty'|trans }}</li>
                    {% endfor %}
                </ul>
            </section>

            <div class="auth-actions-inline">
                <a class="auth-button-link" href="{{ path('app_change_password', { _locale: app.request.locale }) }}">{{ 'dashboard.header.change_password'|trans }}</a>
                <a class="auth-button-link auth-button-link-secondary" href="{{ path('app_home', { _locale: app.request.locale }) }}">{{ 'security.change_password.to_home'|trans }}</a>
                {% if googleLinked %}
                    <form method="post" action="{{ path('app_account_security_unlink_google', { _locale: app.request.locale }) }}" class="account-security-unlink-form">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('account_unlink_google') }}">
                        <button class="auth-button-link auth-button-link-danger" type="submit" {% if not localPasswordEnabled %}disabled title="{{ 'security.account.unlink_google_disabled_reason'|trans }}"{% endif %}>{{ 'security.account.unlink_google'|trans }}</button>
                    </form>
                {% endif %}
            </div>
            {% if googleLinked and not localPasswordEnabled %}
                <p class="account-security-help">{{ 'security.account.unlink_google_disabled_reason'|trans }}</p>
            {% endif %}
        </section>
    </main>
{% endblock %}
