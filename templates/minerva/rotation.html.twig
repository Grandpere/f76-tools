{% extends 'base.html.twig' %}

{% block title %}{{ 'minerva.page_title'|trans }}{% endblock %}

{% block body %}
    {% if catalogUpdatedAt %}
        {% set minervaUpdatedLabel = 'minerva.catalog_last_updated'|trans({'%date%': catalogUpdatedAt|date('d/m/Y H:i')}) %}
    {% else %}
        {% set minervaUpdatedLabel = 'minerva.catalog_last_updated_unknown'|trans %}
    {% endif %}
    {% set minervaTimezoneLabel = 'minerva.timezone'|trans({'%timezone%': timeline.timezone}) %}
    {% set uiTranslations = {
        loadingPlayers: 'dashboard.state.loading_players'|trans,
        cannotLoadPlayers: 'dashboard.state.cannot_load_players'|trans,
        noPlayers: 'dashboard.state.no_players'|trans,
        noSelectedPlayer: 'dashboard.state.no_selected_player'|trans,
        loadingItems: 'dashboard.state.loading_items'|trans,
        loadItemsError: 'dashboard.state.load_items_error'|trans,
        updateFailed: 'dashboard.state.update_failed'|trans,
        noBookFound: 'dashboard.empty.no_book'|trans,
        listPrefix: 'dashboard.labels.list_prefix'|trans,
        dailyOpsReward: 'dashboard.item.daily_ops_reward'|trans,
        ariaItemLearned: 'dashboard.aria.item_learned'|trans,
        sourceFiltersPrefix: 'dashboard.state.source_filters_prefix'|trans,
        visibleItems: 'dashboard.state.visible_items'|trans,
        searchFilterPrefix: 'dashboard.state.search_filter_prefix'|trans,
        source_dropDailyOps: 'dashboard.sources.daily_ops'|trans,
        source_vendorRegs: 'dashboard.sources.regs'|trans,
        source_vendorSamuel: 'dashboard.sources.samuel'|trans,
        source_vendorMortimer: 'dashboard.sources.mortimer'|trans
    } %}
    <main class="catalog-page">
        {% include '_app_page_header.html.twig' with {
            localeSelectId: 'minerva-header-locale-select',
            title: 'minerva.title',
            subtitle: 'minerva.description',
            activeNav: 'minerva',
            extraState: minervaTimezoneLabel ~ ' · ' ~ minervaUpdatedLabel
        } %}

        <section class="catalog-block">
            {% set nextWindow = timeline.upcoming|first %}
            {% if timeline.current %}
                {% set countdownTitle = 'minerva.countdown_title_active'|trans %}
                {% set countdownText = 'minerva.countdown_active_intro'|trans({
                    '%location%': '<strong>' ~ timeline.current.location|e ~ '</strong>',
                    '%list%': '<strong>' ~ timeline.current.listCycle ~ '</strong>'
                }) %}
                {% set countdownTargetDate = timeline.current.endsAt %}
                {% set countdownLabel = 'minerva.countdown_leaves_in'|trans %}
            {% elseif nextWindow %}
                {% set countdownTitle = 'minerva.countdown_title_upcoming'|trans %}
                {% set countdownText = 'minerva.countdown_upcoming_intro'|trans({
                    '%location%': '<strong>' ~ nextWindow.location|e ~ '</strong>',
                    '%list%': '<strong>' ~ nextWindow.listCycle ~ '</strong>'
                }) %}
                {% set countdownTargetDate = nextWindow.startsAt %}
                {% set countdownLabel = 'minerva.countdown_arrives_in'|trans %}
            {% else %}
                {% set countdownTitle = 'minerva.countdown_title_empty'|trans %}
                {% set countdownText = 'minerva.countdown_empty_intro'|trans %}
                {% set countdownTargetDate = null %}
                {% set countdownLabel = '' %}
            {% endif %}

            <article class="minerva-countdown-card"
                     {% if countdownTargetDate %}
                         data-controller="minerva-countdown"
                         data-minerva-countdown-target-date-value="{{ countdownTargetDate }}"
                     {% endif %}
            >
                <h2>{{ countdownTitle }}</h2>
                <p>{{ countdownText|raw }}</p>
                {% if countdownTargetDate %}
                    <p class="minerva-countdown-label">{{ countdownLabel }}</p>
                    <div class="minerva-countdown-grid" aria-live="polite">
                        <div class="minerva-countdown-box">
                            <span class="minerva-countdown-value" data-minerva-countdown-target="days">00</span>
                            <small>{{ 'minerva.countdown_days'|trans }}</small>
                        </div>
                        <div class="minerva-countdown-box">
                            <span class="minerva-countdown-value" data-minerva-countdown-target="hours">00</span>
                            <small>{{ 'minerva.countdown_hours'|trans }}</small>
                        </div>
                        <div class="minerva-countdown-box">
                            <span class="minerva-countdown-value" data-minerva-countdown-target="minutes">00</span>
                            <small>{{ 'minerva.countdown_minutes'|trans }}</small>
                        </div>
                        <div class="minerva-countdown-box">
                            <span class="minerva-countdown-value" data-minerva-countdown-target="seconds">00</span>
                            <small>{{ 'minerva.countdown_seconds'|trans }}</small>
                        </div>
                    </div>
                {% endif %}
            </article>
        </section>

        <section class="catalog-block">
            <div class="minerva-window-grid">
                <article class="minerva-window-card">
                    <h2>{{ 'minerva.current_window_title'|trans }}</h2>
                    {% if timeline.current %}
                        <p><strong>{{ timeline.current.location }}</strong></p>
                        <p>{{ 'minerva.list_label'|trans({'%list%': timeline.current.listCycle}) }}</p>
                        <p>{{ timeline.current.startsAt|date('D d M Y · H:i') }} → {{ timeline.current.endsAt|date('D d M Y · H:i') }}</p>
                    {% else %}
                        <p>{{ 'minerva.current_window_empty'|trans }}</p>
                    {% endif %}
                </article>
                <article class="minerva-window-card">
                    <h2>{{ 'minerva.next_windows_title'|trans }}</h2>
                    {% if timeline.upcoming %}
                        <ol class="minerva-upcoming-list">
                            {% for row in timeline.upcoming %}
                                <li class="minerva-upcoming-item">
                                    <div class="minerva-upcoming-main">
                                        <span class="item-pill">{{ 'minerva.list_label'|trans({'%list%': row.listCycle}) }}</span>
                                        <strong>{{ row.location }}</strong>
                                    </div>
                                    <div class="minerva-upcoming-dates">
                                        <span>{{ 'minerva.starts_at'|trans }}: {{ row.startsAt|date('D d M Y · H:i') }}</span>
                                        <span>{{ 'minerva.ends_at'|trans }}: {{ row.endsAt|date('D d M Y · H:i') }}</span>
                                    </div>
                                </li>
                            {% endfor %}
                        </ol>
                    {% else %}
                        <p>{{ 'minerva.empty'|trans }}</p>
                    {% endif %}
                </article>
            </div>
            <section class="catalog-panel minerva-active-windows-panel">
                <h2>{{ 'minerva.active_windows_title'|trans }}</h2>
                <div class="minerva-table-wrap">
                    <table
                        class="minerva-table minerva-timeline-table"
                        data-controller="minerva-progression"
                        data-minerva-progression-players-base-url-value="{{ apiPlayersBaseUrl }}"
                        data-minerva-progression-storage-key-value="{{ storageKey }}"
                        data-minerva-progression-locale-value="{{ app.request.locale }}"
                        data-minerva-progression-fallback-player-id-value="{{ activePlayerId ?? '' }}"
                    >
                        <thead>
                        <tr>
                            <th>{{ 'minerva.list_cycle'|trans }}</th>
                            <th>{{ 'minerva.location'|trans }}</th>
                            <th>{{ 'minerva.starts_at'|trans }}</th>
                            <th>{{ 'minerva.ends_at'|trans }}</th>
                            <th>{{ 'minerva.list_progress'|trans }}</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for row in timelineTablePagination.rows %}
                            <tr>
                                <td>{{ row.listCycle }}</td>
                                <td>{{ row.location }}</td>
                                <td>{{ row.startsAt|date('D d M Y · H:i') }}</td>
                                <td>{{ row.endsAt|date('D d M Y · H:i') }}</td>
                                <td data-minerva-progression-target="cell" data-list-cycle="{{ row.listCycle }}">
                                    <div class="minerva-progress-cell">
                                        <div class="minerva-progress-meta" data-minerva-progress-meta>-</div>
                                        <div class="minerva-progress-track" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0">
                                            <span class="minerva-progress-fill" data-minerva-progress-fill style="width: 0%;"></span>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                        {% if timelineTablePagination.rows is empty %}
                            <tr>
                                <td colspan="5">{{ 'minerva.empty'|trans }}</td>
                            </tr>
                        {% endif %}
                        </tbody>
                    </table>
                </div>
                {% if timelineTablePagination.pageCount > 1 %}
                    <nav class="catalog-pagination minerva-pagination" aria-label="Minerva upcoming windows pagination">
                        {% if timelineTablePagination.currentPage > 1 %}
                            <a
                                class="catalog-pagination-link"
                                href="{{ path('app_minerva_rotation', app.request.query.all|merge({'page': timelineTablePagination.currentPage - 1})) }}"
                            >
                                {{ 'minerva.pagination_prev'|trans }}
                            </a>
                        {% else %}
                            <span class="catalog-pagination-link is-disabled">{{ 'minerva.pagination_prev'|trans }}</span>
                        {% endif %}

                        <span class="catalog-pagination-current">
                            {{ 'minerva.pagination_page'|trans({
                                '%page%': timelineTablePagination.currentPage,
                                '%total%': timelineTablePagination.pageCount
                            }) }}
                        </span>

                        {% if timelineTablePagination.currentPage < timelineTablePagination.pageCount %}
                            <a
                                class="catalog-pagination-link"
                                href="{{ path('app_minerva_rotation', app.request.query.all|merge({'page': timelineTablePagination.currentPage + 1})) }}"
                            >
                                {{ 'minerva.pagination_next'|trans }}
                            </a>
                        {% else %}
                            <span class="catalog-pagination-link is-disabled">{{ 'minerva.pagination_next'|trans }}</span>
                        {% endif %}
                    </nav>
                {% endif %}
            </section>
        </section>

        <section
            class="minerva-knowledge-stack"
            data-controller="minerva-knowledge"
            data-minerva-knowledge-players-url-value="{{ apiPlayersUrl }}"
            data-minerva-knowledge-players-base-url-value="{{ apiPlayersBaseUrl }}"
            data-minerva-knowledge-initial-player-id-value="{{ activePlayerId ?? '' }}"
            data-minerva-knowledge-storage-key-value="{{ storageKey }}"
            data-minerva-knowledge-locale-value="{{ app.request.locale }}"
            data-minerva-knowledge-ui-translations-value="{{ uiTranslations|json_encode|e('html_attr') }}"
        >
            <section class="catalog-panel filters-panel">
                <h2>{{ 'dashboard.filters.title'|trans }}</h2>
                {% include '_catalog_player_search_filters.html.twig' with { targetPrefix: 'minerva-knowledge' } %}
                {% include '_catalog_source_filters.html.twig' with {
                    targetPrefix: 'minerva-knowledge',
                    filters: [
                        { value: 'dropDailyOps', icon: '/assets/icons/FO76_dailyops_uplink.png', labelKey: 'dashboard.sources.daily_ops' },
                        { value: 'vendorRegs', icon: '/assets/icons/Vault79Marker.svg', labelKey: 'dashboard.sources.regs' },
                        { value: 'vendorSamuel', icon: '/assets/icons/HammerWingMarker.svg', labelKey: 'dashboard.sources.samuel' },
                        { value: 'vendorMortimer', icon: '/assets/icons/SkullRingMarker.svg', labelKey: 'dashboard.sources.mortimer' }
                    ]
                } %}
                {% include '_catalog_state_line.html.twig' with { targetPrefix: 'minerva-knowledge' } %}
            </section>

            <section class="catalog-panel minerva-books-panel">
                <h2>{{ 'dashboard.catalog.book_title'|trans }}</h2>
                <p class="catalog-note info-note">
                    <span class="info-note-content">{{ 'minerva.help.shared_book_learning'|trans }}</span>
                </p>
                <div data-minerva-knowledge-target="bookList"></div>
            </section>
        </section>
    </main>
{% endblock %}
