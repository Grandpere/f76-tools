{% extends 'base.html.twig' %}

{% block title %}{{ 'minerva.page_title'|trans }}{% endblock %}

{% block body %}
    <main class="catalog-page translations-page">
        <header class="catalog-header">
            <div class="catalog-header-tools">
                {% if is_granted('ROLE_ADMIN') %}
                    <a class="header-translations-link" href="{{ path('app_admin_users', { locale: app.request.locale }) }}">{{ 'dashboard.header.admin'|trans }}</a>
                {% endif %}
                <form method="post" action="{{ path('app_logout', { locale: app.request.locale }) }}" class="logout-form header-logout-form">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
                    <button type="submit"><img class="logout-icon" src="/assets/icons/logout.svg" alt="" aria-hidden="true"> {{ 'dashboard.header.logout'|trans }}</button>
                </form>
                <form class="header-locale" method="get">
                    <img class="header-locale-icon" src="/assets/icons/language.svg" alt="" aria-hidden="true">
                    <label for="minerva-header-locale-select">{{ 'common.language'|trans }}</label>
                    <select id="minerva-header-locale-select" name="locale" onchange="this.form.submit()">
                        <option value="fr" {% if app.request.locale == 'fr' %}selected{% endif %}>🇫🇷 {{ 'common.locale.fr'|trans }}</option>
                        <option value="en" {% if app.request.locale == 'en' %}selected{% endif %}>🇬🇧 {{ 'common.locale.en'|trans }}</option>
                        <option value="de" {% if app.request.locale == 'de' %}selected{% endif %}>🇩🇪 {{ 'common.locale.de'|trans }}</option>
                    </select>
                </form>
            </div>
            <p class="catalog-kicker">Fallout 76</p>
            <h1>{{ 'minerva.title'|trans }}</h1>
            <p class="catalog-subtitle">{{ 'minerva.description'|trans }}</p>
            <p class="catalog-user">
                {{ 'dashboard.header.greeting_prefix'|trans }} <strong>{{ username }}</strong> ·
                <a href="{{ path('app_dashboard', { locale: app.request.locale }) }}">{{ 'dashboard.header.title'|trans }}</a>
                ·
                <span>{{ 'dashboard.header.minerva_rotation'|trans }}</span>
            </p>
            <p class="catalog-state">{{ 'minerva.timezone'|trans({'%timezone%': timeline.timezone}) }}</p>
        </header>

        <section class="translations-panel">
            {% set nextWindow = timeline.upcoming|first %}
            {% if timeline.current %}
                {% set countdownTitle = 'minerva.countdown_title_active'|trans %}
                {% set countdownText = 'minerva.countdown_active_intro'|trans({
                    '%location%': timeline.current.location,
                    '%list%': timeline.current.listCycle
                }) %}
                {% set countdownTargetDate = timeline.current.endsAt %}
                {% set countdownLabel = 'minerva.countdown_leaves_in'|trans %}
            {% elseif nextWindow %}
                {% set countdownTitle = 'minerva.countdown_title_upcoming'|trans %}
                {% set countdownText = 'minerva.countdown_upcoming_intro'|trans({
                    '%location%': nextWindow.location,
                    '%list%': nextWindow.listCycle
                }) %}
                {% set countdownTargetDate = nextWindow.startsAt %}
                {% set countdownLabel = 'minerva.countdown_arrives_in'|trans %}
            {% else %}
                {% set countdownTitle = 'minerva.countdown_title_empty'|trans %}
                {% set countdownText = 'minerva.countdown_empty_intro'|trans %}
                {% set countdownTargetDate = null %}
                {% set countdownLabel = '' %}
            {% endif %}

            <article class="minerva-countdown-card"
                     {% if countdownTargetDate %}
                         data-controller="minerva-countdown"
                         data-minerva-countdown-target-date-value="{{ countdownTargetDate }}"
                     {% endif %}
            >
                <h2>{{ countdownTitle }}</h2>
                <p>{{ countdownText }}</p>
                {% if countdownTargetDate %}
                    <p class="minerva-countdown-label">{{ countdownLabel }}</p>
                    <div class="minerva-countdown-grid" aria-live="polite">
                        <div class="minerva-countdown-box">
                            <span class="minerva-countdown-value" data-minerva-countdown-target="days">00</span>
                            <small>{{ 'minerva.countdown_days'|trans }}</small>
                        </div>
                        <div class="minerva-countdown-box">
                            <span class="minerva-countdown-value" data-minerva-countdown-target="hours">00</span>
                            <small>{{ 'minerva.countdown_hours'|trans }}</small>
                        </div>
                        <div class="minerva-countdown-box">
                            <span class="minerva-countdown-value" data-minerva-countdown-target="minutes">00</span>
                            <small>{{ 'minerva.countdown_minutes'|trans }}</small>
                        </div>
                        <div class="minerva-countdown-box">
                            <span class="minerva-countdown-value" data-minerva-countdown-target="seconds">00</span>
                            <small>{{ 'minerva.countdown_seconds'|trans }}</small>
                        </div>
                    </div>
                {% endif %}
            </article>

            <div class="minerva-window-grid">
                <article class="minerva-window-card">
                    <h2>{{ 'minerva.current_window_title'|trans }}</h2>
                    {% if timeline.current %}
                        <p><strong>{{ timeline.current.location }}</strong></p>
                        <p>{{ 'minerva.list_label'|trans({'%list%': timeline.current.listCycle}) }}</p>
                        <p>{{ timeline.current.startsAt|date('Y-m-d H:i') }} → {{ timeline.current.endsAt|date('Y-m-d H:i') }}</p>
                        <p><span class="item-pill">{{ ('minerva.status_' ~ timeline.current.status)|trans }}</span></p>
                    {% else %}
                        <p>{{ 'minerva.current_window_empty'|trans }}</p>
                    {% endif %}
                </article>
                <article class="minerva-window-card">
                    <h2>{{ 'minerva.next_windows_title'|trans }}</h2>
                    {% if timeline.upcoming %}
                        <ol class="minerva-upcoming-list">
                            {% for row in timeline.upcoming %}
                                <li class="minerva-upcoming-item">
                                    <div class="minerva-upcoming-main">
                                        <span class="item-pill">{{ 'minerva.list_label'|trans({'%list%': row.listCycle}) }}</span>
                                        <strong>{{ row.location }}</strong>
                                    </div>
                                    <div class="minerva-upcoming-dates">
                                        <span>{{ 'minerva.starts_at'|trans }}: {{ row.startsAt|date('D d M Y · H:i') }}</span>
                                        <span>{{ 'minerva.ends_at'|trans }}: {{ row.endsAt|date('D d M Y · H:i') }}</span>
                                    </div>
                                </li>
                            {% endfor %}
                        </ol>
                    {% else %}
                        <p>{{ 'minerva.empty'|trans }}</p>
                    {% endif %}
                </article>
            </div>
            <div class="translations-table-wrap">
                <table
                    class="translations-table minerva-timeline-table"
                    data-controller="minerva-progression"
                    data-minerva-progression-players-base-url-value="{{ apiPlayersBaseUrl }}"
                    data-minerva-progression-storage-key-value="{{ storageKey }}"
                    data-minerva-progression-locale-value="{{ app.request.locale }}"
                    data-minerva-progression-fallback-player-id-value="{{ activePlayerId ?? '' }}"
                >
                    <thead>
                    <tr>
                        <th>{{ 'minerva.list_cycle'|trans }}</th>
                        <th>{{ 'minerva.location'|trans }}</th>
                        <th>{{ 'minerva.starts_at'|trans }}</th>
                        <th>{{ 'minerva.ends_at'|trans }}</th>
                        <th>{{ 'minerva.status'|trans }}</th>
                        <th>{{ 'minerva.list_progress'|trans }}</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for row in timeline.rows %}
                        <tr>
                            <td>{{ row.listCycle }}</td>
                            <td>{{ row.location }}</td>
                            <td>{{ row.startsAt|date('Y-m-d H:i') }}</td>
                            <td>{{ row.endsAt|date('Y-m-d H:i') }}</td>
                            <td><span class="item-pill">{{ ('minerva.status_' ~ row.status)|trans }}</span></td>
                            <td data-minerva-progression-target="cell" data-list-cycle="{{ row.listCycle }}">
                                <div class="minerva-progress-cell">
                                    <div class="minerva-progress-meta" data-minerva-progress-meta>-</div>
                                    <div class="minerva-progress-track" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0">
                                        <span class="minerva-progress-fill" data-minerva-progress-fill style="width: 0%;"></span>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6">{{ 'minerva.empty'|trans }}</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>
    </main>
{% endblock %}
